+
+RUN_DIR = Path(__file__).resolve().parent
+REPO_ROOT = Path("/Users/sungs/ai-lab/sources/checkouts/btc_benchmark")
+TEAM = "ai_lab_autoresearch_cycle2_223228"
+ALWAYS_LONG_FLOOR = 1.5005
+PREFLIGHT_EMA_NET = -0.8668
