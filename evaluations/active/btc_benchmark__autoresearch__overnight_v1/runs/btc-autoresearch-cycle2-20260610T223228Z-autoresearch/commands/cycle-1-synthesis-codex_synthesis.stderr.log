+uv run python /Users/sungs/ai-lab/evaluations/active/btc_benchmark__autoresearch__overnight_v1/runs/btc-autoresearch-cycle2-20260610T223228Z-autoresearch/run_cycle2_buyhold_relative_sweep.py
