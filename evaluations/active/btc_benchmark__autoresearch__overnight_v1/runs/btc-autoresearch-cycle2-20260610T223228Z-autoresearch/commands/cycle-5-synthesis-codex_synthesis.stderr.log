+        equal = bool(ref_pos.shape == asset_pos.shape and np.array_equal(ref_pos, asset_pos, equal_nan=True))
+        diff = float(np.nanmax(np.abs(ref_pos - asset_pos))) if ref_pos.shape == asset_pos.shape and ref_pos.size else float("inf")
