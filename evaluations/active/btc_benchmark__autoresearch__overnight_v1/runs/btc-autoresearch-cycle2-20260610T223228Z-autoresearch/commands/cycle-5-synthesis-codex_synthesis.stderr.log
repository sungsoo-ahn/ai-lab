+def _funding_rate_by_bar(data: Any, candles: pd.DataFrame) -> np.ndarray:
+    funding = data.aux.get("funding")
+    if funding is None or funding.empty:
+        return np.full(len(candles), np.nan, dtype="float64")
+    left = pd.DataFrame(
+        {
