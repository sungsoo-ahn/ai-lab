+def _apply_persistence(raw: np.ndarray, *, enter_confirm: int, exit_confirm: int, min_hold: int) -> np.ndarray:
+    out = np.zeros(len(raw), dtype="float64")
+    state = 0.0
+    true_run = 0
+    false_run = 0
+    hold = 0
+    for i, value in enumerate(raw):
+        if bool(value):
+            true_run += 1
+            false_run = 0
+        else:
+            false_run += 1
+            true_run = 0
+
+        if state == 0.0:
+            if true_run >= enter_confirm:
+                state = 1.0
+                hold = 0
+        else:
+            hold += 1
+            if hold >= min_hold and false_run >= exit_confirm:
+                state = 0.0
+                hold = 0
+        out[i] = state
+    return out
