                "cycle4_funding5bp_enter3_exit12_min48",
                funding_max=0.0005,
                enter_confirm=3,
                exit_confirm=12,
                min_hold=48,
            ),
            RegimeOverlay(
                "cycle4_funding3bp_enter3_exit12_min48",
