+    abs_sum = sum(abs(x) for x in year_nets)
+    concentration = max((abs(x) for x in year_nets), default=0.0) / abs_sum if abs_sum else None
+    out = dict(report)
+    out["delta_vs_always_long"] = round(float(out["net"]) - ALWAYS_LONG_FLOOR, 4)
