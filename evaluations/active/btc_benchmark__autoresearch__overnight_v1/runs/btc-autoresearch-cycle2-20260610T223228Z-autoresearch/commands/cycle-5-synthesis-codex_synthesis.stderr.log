+    drawdown_improvement = float(report.get("drawdown_improvement_vs_always_long", -999.0))
+    funding = float(report.get("net_funding_aware") or -999.0)
+    cost2 = float(report.get("net_cost2x", -999.0))
+    cost3 = float(report.get("net_cost3x", -999.0))
+    cost5 = float(report.get("net_cost5x", -999.0))
+    next_open = float(report.get("net_next_open", -999.0))
+    concentration = report.get("per_year_abs_net_concentration")
+    concentration_score = 999.0 if concentration is None else -float(concentration)
+    random_pctile = report.get("random_pctile")
+    random_value = -1.0 if random_pctile is None else float(random_pctile)
+    turnover = float(report.get("turnover", 999999.0))
+    return (
+        not bool(report.get("disqualified", True)),
+        delta_bh > 0,
+        cost3 > 0,
+        cost5 > 0,
+        delta_bh,
+        drawdown_improvement,
+        funding,
+        cost2,
+        cost3,
+        cost5,
+        next_open,
+        concentration_score,
+        random_value,
+        -turnover,
+    )
+
+
+def parity_check(data: Any, asset_cls: type) -> dict[str, Any]:
+    wf = WalkForwardConfig.from_dict({**SPLIT, "horizon_bars": 1})
+    splits, holdout = generate_splits(data.candles["timestamp_open"], wf)
+    fold_results = []
+    all_equal = True
+    max_abs_diff = 0.0
+    for split in splits:
+        tr0, tr1 = split.train_range
+        te0, te1 = split.test_range
+        ref = ReferenceRegimeOverlay("cycle5_reference_cycle4_funding3bp_exit6_min24", funding_max=0.0003)
+        asset = asset_cls()
+        ref.fit(data, tr0, tr1)
+        asset.fit(data, tr0, tr1)
+        ref_pos = np.asarray(ref.positions(data, te0, te1), dtype="float64")
+        asset_pos = np.asarray(asset.positions(data, te0, te1), dtype="float64")
+        equal = bool(ref_pos.shape == asset_pos.shape and np.array_equal(ref_pos, asset_pos, equal_nan=True))
+        diff = float(np.nanmax(np.abs(ref_pos - asset_pos))) if ref_pos.shape == asset_pos.shape and ref_pos.size else float("inf")
+        all_equal = all_equal and equal
+        max_abs_diff = max(max_abs_diff, diff)
+        fold_results.append(
+            {
+                "fold": int(split.split_id),
+                "train_range": [int(tr0), int(tr1)],
+                "test_range": [int(te0), int(te1)],
+                "equal": equal,
+                "ref_position_sum": float(np.nansum(ref_pos)),
+                "asset_position_sum": float(np.nansum(asset_pos)),
+                "max_abs_diff": diff,
+            }
+        )
+    return {
+        "asset_path": str(ASSET_PATH),
+        "n_folds": len(splits),
+        "holdout_start_idx": holdout.get("start_idx"),
+        "all_equal": all_equal,
+        "max_abs_diff": max_abs_diff,
+        "folds": fold_results,
+    }
+
+
+def candidate_set(asset_cls: type) -> list[Any]:
+    return [
+        asset_cls(),
+        asset_cls(name="cycle5_asset_funding8bp_exit6_min24", funding_max=0.0008),
+        asset_cls(name="cycle5_asset_funding5bp_exit6_min48", funding_max=0.0005, min_hold=48),
+        asset_cls(name="cycle5_asset_funding5bp_exit12_min48", funding_max=0.0005, exit_confirm=12, min_hold=48),
+    ]
+
+
+def main() -> None:
+    data = load_benchmark_data(REPO_ROOT, include_sub_bars=False)
+    asset_cls = load_asset_class()
+    reports_dir = RUN_DIR / "cycle5_candidate_reports"
+    reports_dir.mkdir(exist_ok=True)
+    leaderboard = RUN_DIR / "cycle5_candidate_leaderboard.jsonl"
+    if leaderboard.exists():
+        leaderboard.unlink()
+
+    parity = parity_check(data, asset_cls)
+    (RUN_DIR / "cycle5_position_parity.json").write_text(json.dumps(parity, indent=2, default=str) + "\n")
+
+    reports = []
+    for strategy in candidate_set(asset_cls):
+        report = annotate(
+            run_benchmark(
+                strategy,
+                data,
+                gates=True,
+                leaderboard_path=leaderboard,
+                team=TEAM,
+            )
+        )
+        reports.append(report)
+        (reports_dir / f"{strategy.name}.json").write_text(json.dumps(report, indent=2, default=str) + "\n")
+
+    ranked = sorted(reports, key=decision_key, reverse=True)
+    summary = {
+        "parity_all_equal": parity["all_equal"],
+        "parity_max_abs_diff": parity["max_abs_diff"],
+        "ranked": [compact_record(i + 1, report) for i, report in enumerate(ranked)],
+    }
+    (RUN_DIR / "cycle5_candidate_summary.json").write_text(json.dumps(summary, indent=2, default=str) + "\n")
+
+
+if __name__ == "__main__":
+    main()

