+            "next_open": r["net_next_open"],
+            "funding_aware": r["net_funding_aware"],
+            "random_pctile": r["random_pctile"],
+        }
+        for r in summary_rows
+    ]
+    (RUN_DIR / "candidate_summary.json").write_text(json.dumps(compact, indent=2) + "\n")
