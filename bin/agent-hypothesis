#!/bin/sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

usage() {
  echo "Deprecated: use ai-lab work-unit instead." >&2
  echo "Usage: agent-hypothesis <init|close> <project_id> <hypothesis_id>" >&2
}

[ "$#" -ge 3 ] || { usage; exit 2; }
cmd="$1"
project_id="$2"
work_unit_id="$3"
scientists_dir="$root/tasks/active/$project_id/scientists"

[ -d "$scientists_dir" ] || { echo "Task not found: $project_id" >&2; exit 1; }
scientist_count="$(find "$scientists_dir" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
[ "$scientist_count" = "1" ] || { echo "Specify scientist with ai-lab work-unit; found $scientist_count scientists." >&2; exit 1; }
scientist_id="$(basename "$(find "$scientists_dir" -mindepth 1 -maxdepth 1 -type d | sed -n '1p')")"

case "$cmd" in
  init)
    exec "$root/bin/ai-lab" work-unit init "$project_id" "$scientist_id" "$work_unit_id"
    ;;
  close)
    exec "$root/bin/ai-lab" work-unit close "$project_id" "$scientist_id" "$work_unit_id"
    ;;
  *)
    usage
    exit 2
    ;;
esac
