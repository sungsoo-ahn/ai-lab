#!/usr/bin/env python3
from __future__ import annotations

import argparse
import datetime as dt
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
ACTIVE = ROOT / "tasks" / "active"
WORK_UNITS = {
    "baseline_reproduction": {
        "purpose": "Build readiness, run tests, build required data, reproduce the 60-trial baseline, and run M5.5 audit.",
        "scope": "BTC scientist files, work-unit report, and generated data/results in the shared BTC source checkout.",
    },
    "pipeline_audit": {
        "purpose": "Audit leakage, cost, holdout, and reproducibility risks; produce actionable blockers and safe next steps.",
        "scope": "Read-only code inspection plus work-unit report updates.",
    },
    "horizon_h4_audit": {
        "purpose": "Investigate the documented H=4 horizon-matched lead after baseline artifacts exist.",
        "scope": "Own work-unit report and isolated generated outputs; no core evaluation rule changes.",
    },
    "regime_filter_probe": {
        "purpose": "Try a bounded volatility/regime-filter workstream after baseline reproduction passes.",
        "scope": "Own branch/patch or isolated worktree if code edits are needed.",
    },
    "report_synthesis": {
        "purpose": "Summarize all overnight results, negative findings, package installs, and next actions for the user.",
        "scope": "Project report, run summary, and work-unit reports.",
    },
}


def today() -> str:
    return dt.date.today().isoformat()


def timestamp() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def write_new(path: Path, text: str) -> None:
    if path.exists():
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")


def project_dir(task_id: str) -> Path:
    if "/" in task_id or task_id in {"", ".", ".."}:
        raise SystemExit("Invalid task_id.")
    p = ACTIVE / task_id / "scientists" / "btc_autoresearch_v1"
    if not p.exists():
        raise SystemExit(f"Task scientist not found: {task_id}")
    return p


def init_work_unit(task_id: str, work_unit_id: str, purpose: str, scope: str) -> None:
    p = project_dir(task_id)
    h = p / "work_units" / work_unit_id
    h.mkdir(parents=True, exist_ok=True)
    for d in ["memory", "runs"]:
        (h / d).mkdir(exist_ok=True)
    write_new(
        h / "README.md",
        f"""# Work Unit: {work_unit_id}

This is a work-unit workspace for the `{task_id}` task and `btc_autoresearch_v1` scientist.

Purpose: {purpose}

Allowed write scope: {scope}
""",
    )
    write_new(
        h / "work-unit.yaml",
        f"""work_unit_id: {work_unit_id}
task_id: {task_id}
scientist_id: btc_autoresearch_v1
type: observation
status: active
created_at: {today()}
updated_at: {today()}
parallel_safe: true
claimed_by: null
run_id: null
touch_scope: scientist_owned_files
conflicts_with: []
proposal_refs: []
statement: {purpose}
method: Overnight research work unit.
expected_signal: Useful scientist knowledge, verified baseline state, or bounded improvement candidate.
assets_used:
  - upstream_repo
  - btcusdt_futures_1h_dataset
source_refs:
  - source_id: btc_autoresearch
    git_ref: ca251130e1f97b6233ceb957cb85e209bc136073
    purpose: Optimized BTC AutoResearch codebase for this work unit.
evaluation_plan: Follow the overnight runbook and write a complete work-unit report.
outcome: null
decision: pending
reports:
  current: report.md
""",
    )
    write_new(
        h / "report.md",
        f"""# Work Unit Report: {work_unit_id}

Date: {today()}
Status: active

## Purpose

{purpose}

## Commands Run

```sh
none yet
```

## Package Installs

none yet

## Files Changed

- none yet

## Outputs

- none yet

## Result

No result yet.

## Safety Checklist

- Sealed holdout used: no
- Failed trials preserved: not applicable
- Backtester/accounting rules changed: no
- Live trading/API keys used: no

## Recommendation

continue
""",
    )
    write_new(h / "memory" / "README.md", "# Work Unit Memory\n\nAgent-facing work-unit memory lives here.\n")
    write_new(h / "runs" / "README.md", "# Work Unit Runs\n\nRun records for this work unit live here.\n")


def cmd_prepare(args: argparse.Namespace) -> None:
    p = project_dir(args.task_id)
    run_id = args.run_id or f"overnight-{timestamp()}"
    run_dir = p / "runs" / run_id
    run_dir.mkdir(parents=True, exist_ok=True)
    for work_unit_id, meta in WORK_UNITS.items():
        init_work_unit(args.task_id, work_unit_id, meta["purpose"], meta["scope"])
    write_new(
        p / "overnight-runbook.md",
        f"""# Overnight Runbook: {args.task_id}

Date: {today()}
Status: ready
Run ID: {run_id}

## Goal

Run a full BTC research loop overnight. First verify environment, data, and baseline reproduction. Then let bounded work units pursue useful observations or improvements.

## Autonomy

- Agents may run a full research loop.
- Agents may silently install missing Python scientist dependencies using inherited repository-local `uv` workflows.
- Agents may edit code only in isolated work units, branches, worktrees, or clearly owned file scopes.
- Agents may not silently install Homebrew, Node, Docker, system packages, connector integrations, shell configuration, or account configuration.

## Gates

1. Verify or materialize source `btc_autoresearch` at git ref `ca251130e1f97b6233ceb957cb85e209bc136073`.
2. Run tests or install missing Python deps with `uv` and record the install.
3. Build required BTCUSDT 1h futures candles if missing.
4. Build funding data if needed for audit.
5. Reproduce 60-trial baseline and M5.5 audit.
6. Launch parallel improvement/knowledge work only after baseline status is known.

## Baseline Commands

```sh
/Users/sungs/ai-lab/bin/ai-lab source status btc_autoresearch
cd /Users/sungs/ai-lab/sources/checkouts/btc_autoresearch
PYTHONDONTWRITEBYTECODE=1 pytest -q -p no:cacheprovider
python -m src.data.download_binance --market futures_um --symbol BTCUSDT --interval 1h --start 2019-09-01
python -m src.data.impute --market futures_um --symbol BTCUSDT --interval 1h --policy flat_bar_fill
python -m src.data.validate_data --market futures_um --symbol BTCUSDT --interval 1h
python -m src.data.download_derivatives --kind funding --symbol BTCUSDT --start 2019-09-09
python -m scripts.run_autoresearch --max-trials 60 --seed 42
python -m scripts.run_m5_5_audit
```

## Work Units

| Work Unit | Purpose | Write Scope |
| --- | --- | --- |
{work_unit_rows()}

## Required Final Outputs

- Update `tasks/active/{args.task_id}/scientists/btc_autoresearch_v1/report.md`.
- Update every work-unit `report.md`.
- Write `tasks/active/{args.task_id}/scientists/btc_autoresearch_v1/runs/{run_id}/overnight-summary.md`.
- Record package installs, commands, failures, outputs, and safety status.
""",
    )
    write_new(
        run_dir / "overnight-summary.md",
        f"""# Overnight Summary: {args.task_id}

Date: {today()}
Run ID: {run_id}
Status: prepared

## Summary

The overnight run has been prepared but not completed.

## Work Units

{chr(10).join(f'- `{key}`: prepared' for key in WORK_UNITS)}

## Package Installs

none recorded yet

## Final Result

No result yet.
""",
    )
    print(f"Prepared {args.task_id} overnight run: {run_id}")
    print(p / "overnight-runbook.md")
    print(run_dir / "overnight-summary.md")


def work_unit_rows() -> str:
    return "\n".join(f"| `{key}` | {meta['purpose']} | {meta['scope']} |" for key, meta in WORK_UNITS.items())


def cmd_prompt(args: argparse.Namespace) -> None:
    p = project_dir(args.task_id)
    print(
        f"""Use the account agent setup. Read ~/AGENTS.md and continue from ~/ai-lab.

/goal Run the overnight BTC research orchestration for task `{args.task_id}`.

Read:
- {p / 'scientist.md'}
- {p / 'scientist.yaml'}
- {p / 'assets.yaml'}
- {p / 'task.md'}
- {p / 'overnight-runbook.md'}

Operate as the orchestration agent. Use work-unit folders under `{p / 'work_units'}`. First verify source `btc_autoresearch` with `/Users/sungs/ai-lab/bin/ai-lab source status btc_autoresearch`, then complete the readiness and baseline-reproduction gate from the shared checkout. If missing Python dependencies block progress, install them silently with inherited repository-local uv workflows and record the exact command. Do not install Homebrew, Node, Docker, connector integrations, shell config, or account config silently.

After baseline status is known, run bounded work units. Preserve failed trials, never touch sealed holdout during research, never place live orders or use private API keys, and never weaken accounting/cost/timestamp/split rules to improve results.

Before stopping, update `{p / 'report.md'}`, each work-unit report, and the active overnight summary under `{p / 'runs'}`.
"""
    )


def main() -> None:
    parser = argparse.ArgumentParser(description="Prepare and describe overnight scientist runs.")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("prepare", help="create overnight runbook and work-unit scaffolding")
    p.add_argument("task_id")
    p.add_argument("--run-id")
    p.set_defaults(func=cmd_prepare)
    p = sub.add_parser("prompt", help="print an orchestration prompt")
    p.add_argument("task_id")
    p.set_defaults(func=cmd_prompt)
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
