#!/usr/bin/env python3
from __future__ import annotations

import argparse
import datetime as dt
import re
import sqlite3
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
DB = ROOT / "memory" / "index.sqlite"
SECRET_PATTERNS = [
    re.compile(r"(?i)(api[_-]?key|token|secret|password)\s*[:=]\s*[A-Za-z0-9_\-]{12,}"),
    re.compile(r"xox[baprs]-[A-Za-z0-9-]{20,}"),
    re.compile(r"xapp-[A-Za-z0-9-]{20,}"),
    re.compile(r"-----BEGIN (?:RSA |OPENSSH |EC |DSA )?PRIVATE KEY-----"),
]


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def rel(path: Path) -> str:
    return str(path.relative_to(ROOT))


def classify(path: Path) -> tuple[str, str | None, str | None, str]:
    parts = path.relative_to(ROOT).parts
    owner_id = None
    sub_id = None
    scope = "lab"
    kind = path.suffix.lstrip(".") or "text"
    if len(parts) >= 2 and parts[0] == "tasks":
        owner_id = parts[1]
        scope = "task"
        if "runs" in parts:
            i = parts.index("runs")
            if len(parts) > i + 1:
                sub_id = parts[i + 1]
                scope = "task_run"
    elif parts[0] == "logs":
        scope = "log"
    return scope, owner_id, sub_id, kind


def title_for(path: Path, text: str) -> str:
    in_frontmatter = False
    seen_frontmatter = False
    for line in text.splitlines():
        line = line.strip()
        if line == "---" and not seen_frontmatter:
            in_frontmatter = True
            seen_frontmatter = True
            continue
        if line == "---" and in_frontmatter:
            in_frontmatter = False
            continue
        if in_frontmatter:
            continue
        if line.startswith("#"):
            return line.lstrip("#").strip()
        if line:
            return line[:120]
    return path.name


def iter_docs():
    skip_dirs = {".git", ".venv", "__pycache__", ".pytest_cache", ".ruff_cache"}
    suffixes = {".md", ".yaml", ".yml", ".json", ".txt"}
    for path in ROOT.rglob("*"):
        if not path.is_file() or path.suffix not in suffixes:
            continue
        if any(part in skip_dirs for part in path.parts):
            continue
        if path == DB:
            continue
        try:
            text = path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            continue
        yield path, text


def build_index(_: argparse.Namespace) -> None:
    DB.parent.mkdir(parents=True, exist_ok=True)
    con = sqlite3.connect(DB)
    con.execute("drop table if exists documents")
    con.execute(
        """
        create table documents (
          path text primary key,
          scope text not null,
          project_id text,
          hypothesis_id text,
          kind text not null,
          title text,
          body text not null,
          mtime real not null
        )
        """
    )
    rows = []
    for path, text in iter_docs():
        scope, project_id, hypothesis_id, kind = classify(path)
        rows.append((rel(path), scope, project_id, hypothesis_id, kind, title_for(path, text), text, path.stat().st_mtime))
    con.executemany("insert into documents values (?, ?, ?, ?, ?, ?, ?, ?)", rows)
    con.execute("create index documents_scope_idx on documents(scope, project_id, hypothesis_id)")
    con.commit()
    con.close()
    print(f"Indexed {len(rows)} files into {rel(DB)}")


def search(args: argparse.Namespace) -> None:
    if not DB.exists():
        build_index(args)
    terms = [t.lower() for t in args.query]
    con = sqlite3.connect(DB)
    rows = con.execute("select path, scope, project_id, hypothesis_id, title, body from documents").fetchall()
    con.close()
    hits = []
    for path, scope, project_id, hypothesis_id, title, body in rows:
        hay = f"{path}\n{title}\n{body}".lower()
        if all(term in hay for term in terms):
            hits.append((path, scope, project_id, hypothesis_id, title))
    for path, scope, project_id, hypothesis_id, title in hits[: args.limit]:
        owner = project_id or "-"
        sub = hypothesis_id or "-"
        print(f"{path} | scope={scope} owner={owner} sub={sub} | {title}")
    if not hits:
        print("No matches.")


def audit(_: argparse.Namespace) -> None:
    issues = []
    for path, text in iter_docs():
        for pattern in SECRET_PATTERNS:
            if pattern.search(text):
                issues.append((rel(path), "possible secret or credential-like value"))
                break
    if issues:
        for path, issue in issues:
            print(f"{path}: {issue}")
        raise SystemExit(1)
    print("Audit passed: no obvious secrets found in indexed text files.")


def reflect(args: argparse.Namespace) -> None:
    out = ROOT / "memory" / "reflections" / f"reflection-{now()}.md"
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(
        "\n".join(
            [
                "---",
                f"id: {out.stem}",
                "type: reflection",
                f"created_at: {dt.date.today().isoformat()}",
                "risk: low",
                "status: draft",
                f"source: {args.source}",
                "---",
                "",
                f"# Reflection: {args.source}",
                "",
                "## What Happened",
                "",
                "<Summarize the execution issue or improvement.>",
                "",
                "## Proposed Update",
                "",
                "<Describe the memory, report, template, or local policy-note update.>",
                "",
                "## Rollback",
                "",
                "<Describe how to revert the change.>",
                "",
            ]
        ),
        encoding="utf-8",
    )
    print(rel(out))


def apply_reflection(args: argparse.Namespace) -> None:
    path = (ROOT / args.reflection).resolve()
    if ROOT not in path.parents or path.suffix != ".md":
        raise SystemExit("Reflection must be a Markdown file under ai-lab.")
    print(f"Recorded as apply candidate: {rel(path)}")
    print("V1 does not infer edits from reflection text. Apply concrete low-risk file edits separately, then rebuild the index.")


def main() -> None:
    parser = argparse.ArgumentParser(description="Search and maintain agent memory.")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("index", help="rebuild the SQLite search index")
    p.set_defaults(func=build_index)
    p = sub.add_parser("search", help="search memory, logs, reports, and manifests")
    p.add_argument("query", nargs="+")
    p.add_argument("--limit", type=int, default=25)
    p.set_defaults(func=search)
    p = sub.add_parser("audit", help="scan indexed text files for obvious sensitive values")
    p.set_defaults(func=audit)
    p = sub.add_parser("reflect", help="create a draft retrospective reflection")
    p.add_argument("source")
    p.set_defaults(func=reflect)
    p = sub.add_parser("apply", help="record an apply candidate for a reflection")
    p.add_argument("reflection")
    p.set_defaults(func=apply_reflection)
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
