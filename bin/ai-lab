#!/usr/bin/env python3
from __future__ import annotations

import argparse
import contextlib
import datetime as dt
import fnmatch
import glob
import hashlib
import html
import io
import json
import netrc
import os
import re
import shutil
import subprocess
import sys
import time
import urllib.parse
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
TASKS = ROOT / "tasks"
SOURCES = ROOT / "sources"
SOURCE_REGISTRY = SOURCES / "sources.yaml"
DOCS = ROOT / "docs"
CONFIG = ROOT / "lab.yaml"
TASK_SCHEMA = "ai_lab_task_v1"
LOOP_SCHEMA = "ai_lab_loop_v1"
RUN_SCHEMA = "ai_lab_run_v1"
OBSERVATION_SCHEMA = "ai_lab_observation_v1"
ARTIFACT_SCHEMA = "ai_lab_artifact_v1"
TASK_MEMORY_SCHEMAS = {
    "insights.yaml": ("ai_lab_task_insights_v1", "insights"),
    "negative-results.yaml": ("ai_lab_task_negative_results_v1", "negative_results"),
    "candidates.yaml": ("ai_lab_task_candidates_v1", "candidates"),
    "runs.yaml": ("ai_lab_task_runs_v1", "runs"),
}
SECRET_ENV_RE = re.compile(r"(token|secret|password|passwd|api[_-]?key|private[_-]?key)", re.IGNORECASE)
ALLOWED_PLACEHOLDERS = {"task_id", "run_id", "cycle", "run_dir", "task_dir", "root"}


RUNTIME_PROFILES = {
    "btc-benchmark-python": {
        "homebrew": [],
        "python_imports": ["numpy", "pandas", "scipy"],
        "description": "Python imports needed by the BTC Benchmark checkout.",
    }
}


def today() -> str:
    return dt.date.today().isoformat()


def timestamp() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat()


def safe_id(value: str, label: str) -> str:
    if "/" in value or value in {"", ".", ".."}:
        raise SystemExit(f"Invalid {label}.")
    return value


def doc_slug(value: str) -> str:
    return value.replace("_", "-")


def require_yaml():
    try:
        import yaml  # type: ignore
    except ModuleNotFoundError as exc:
        raise SystemExit("PyYAML is required. Run from the repo with `uv run python bin/ai-lab ...`.") from exc
    return yaml


def load_yaml_file(path: Path) -> dict[str, Any]:
    if not path.exists():
        raise SystemExit(f"YAML file not found: {path}")
    data = require_yaml().safe_load(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise SystemExit(f"YAML file must contain a mapping: {path}")
    return data


def read_yaml_scalar(path: Path, key: str) -> str | None:
    if not path.exists():
        return None
    for raw in path.read_text(encoding="utf-8").splitlines():
        if raw.startswith(f"{key}:"):
            value = raw.split(":", 1)[1].strip().strip("\"'")
            return value or None
    return None


def task_dir(task_id: str) -> Path:
    return TASKS / safe_id(task_id, "task_id")


def task_manifest_path(task_id: str) -> Path:
    return task_dir(task_id) / "task.yaml"


def task_loop_path(task_id: str) -> Path:
    return task_dir(task_id) / "loop.yaml"


def task_memory_dir(task_id: str) -> Path:
    return task_dir(task_id) / "memory"


def task_run_dir(task_id: str, run_id: str) -> Path:
    return task_dir(task_id) / "runs" / safe_id(run_id, "run_id")


def load_lab_config() -> dict[str, Any]:
    return load_yaml_file(CONFIG)


def read_json_file(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Invalid JSON: {rel_display(path)}: {exc}") from exc
    if not isinstance(data, dict):
        raise SystemExit(f"JSON file must contain an object: {rel_display(path)}")
    return data


def write_json_file(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def read_jsonl(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    rows: list[dict[str, Any]] = []
    for lineno, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        if not line.strip():
            continue
        try:
            data = json.loads(line)
        except json.JSONDecodeError as exc:
            raise SystemExit(f"Invalid JSONL: {rel_display(path)}:{lineno}: {exc}") from exc
        if not isinstance(data, dict):
            raise SystemExit(f"JSONL row must contain an object: {rel_display(path)}:{lineno}")
        rows.append(data)
    return rows


def write_jsonl(path: Path, rows: list[dict[str, Any]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    text = "".join(json.dumps(row, sort_keys=True) + "\n" for row in rows)
    path.write_text(text, encoding="utf-8")


def append_jsonl(path: Path, row: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, sort_keys=True) + "\n")


def upsert_jsonl(path: Path, key: str, row: dict[str, Any]) -> None:
    rows = [item for item in read_jsonl(path) if item.get(key) != row.get(key)]
    rows.append(row)
    write_jsonl(path, rows)


def run_git(path: Path, *args: str, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", str(path), *args],
        check=check,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def run_print(cmd: list[str], cwd: Path | None = None, check: bool = False) -> subprocess.CompletedProcess[str]:
    print("+ " + " ".join(cmd))
    return subprocess.run(cmd, cwd=str(cwd) if cwd else None, text=True, check=check)


def run_capture(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess[str]:
    print("+ " + " ".join(cmd))
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def load_sources() -> dict[str, dict[str, Any]]:
    data = load_yaml_file(SOURCE_REGISTRY)
    entries = data.get("sources", [])
    if not isinstance(entries, list):
        raise SystemExit("sources.yaml must contain a list under `sources`.")
    sources: dict[str, dict[str, Any]] = {}
    for entry in entries:
        if not isinstance(entry, dict) or not isinstance(entry.get("source_id"), str):
            raise SystemExit("Every source entry must have a source_id.")
        sources[str(entry["source_id"])] = entry
    return sources


def get_source(source_id: str) -> dict[str, Any]:
    sources = load_sources()
    if source_id not in sources:
        raise SystemExit(f"Unknown source_id: {source_id}")
    return sources[source_id]


def source_path(source: dict[str, Any]) -> Path:
    raw = source.get("materialized_path")
    if not isinstance(raw, str) or not raw:
        raise SystemExit("Source is missing materialized_path.")
    return Path(raw).expanduser()


def cmd_source_status(args: argparse.Namespace) -> None:
    source = get_source(args.source_id)
    path = source_path(source)
    print(f"source_id: {args.source_id}")
    print(f"title: {source.get('title', '')}")
    print(f"remote_url: {source.get('remote_url', '')}")
    print(f"registered_ref: {source.get('git_ref', '')}")
    print(f"materialized_path: {path}")
    if not path.exists():
        print("status: missing")
        return
    head = run_git(path, "rev-parse", "HEAD", check=False)
    print(f"head: {head.stdout.strip() if head.returncode == 0 else 'unknown'}")
    status = run_git(path, "status", "--short", check=False)
    print("working_tree: clean" if not status.stdout.strip() else "working_tree: dirty")
    if status.stdout.strip():
        print(status.stdout.rstrip())


def cmd_source_materialize(args: argparse.Namespace) -> None:
    source = get_source(args.source_id)
    path = source_path(source)
    remote = str(source.get("remote_url") or "")
    ref = args.ref or str(source.get("git_ref") or "")
    if not remote:
        raise SystemExit("Source is missing remote_url.")
    if path.exists() and not args.force:
        raise SystemExit(f"Source path already exists: {path}. Use --force to update.")
    if path.exists():
        run_print(["git", "-C", str(path), "fetch", "--all", "--tags"], check=True)
    else:
        path.parent.mkdir(parents=True, exist_ok=True)
        run_print(["git", "clone", remote, str(path)], check=True)
    if ref:
        run_print(["git", "-C", str(path), "checkout", ref], check=True)
    print(path)


def runtime_profile(name: str) -> dict[str, Any]:
    if name not in RUNTIME_PROFILES:
        raise SystemExit(f"Unknown runtime profile: {name}")
    return RUNTIME_PROFILES[name]


def cmd_runtime_check(args: argparse.Namespace) -> None:
    profile = runtime_profile(args.profile)
    for formula in profile.get("homebrew", []):
        result = run_capture(["brew", "list", "--versions", str(formula)])
        if result.returncode != 0:
            raise SystemExit(f"Missing Homebrew formula for {args.profile}: {formula}")
    imports = [str(item) for item in profile.get("python_imports", [])]
    if imports:
        code = "import " + ", ".join(imports) + "; print('ok')"
        cmd = ["uv", "run", "python", "-c", code]
        result = run_capture(cmd, cwd=Path(args.repo).expanduser() if args.repo else ROOT)
        if result.returncode != 0:
            print(result.stdout, end="")
            print(result.stderr, end="", file=sys.stderr)
            raise SystemExit(result.returncode)
    print(f"runtime ok: {args.profile}")


def cmd_runtime_ensure(args: argparse.Namespace) -> None:
    profile = runtime_profile(args.profile)
    for formula in profile.get("homebrew", []):
        result = run_capture(["brew", "list", "--versions", str(formula)])
        if result.returncode != 0:
            run_print(["brew", "install", str(formula)], check=True)
    cmd_runtime_check(args)


def require_mapping(value: Any, label: str, issues: list[str]) -> dict[str, Any]:
    if isinstance(value, dict):
        return value
    issues.append(f"{label} must be a mapping")
    return {}


def require_list(value: Any, label: str, issues: list[str]) -> list[Any]:
    if isinstance(value, list):
        return value
    issues.append(f"{label} must be a list")
    return []


def command_kind(command: dict[str, Any]) -> str | None:
    kinds = [key for key in ("argv", "script", "builtin") if key in command]
    return kinds[0] if len(kinds) == 1 else None


def collect_placeholders(value: Any) -> set[str]:
    found: set[str] = set()
    if isinstance(value, str):
        found.update(re.findall(r"\{([A-Za-z0-9_]+)\}", value))
    elif isinstance(value, list):
        for item in value:
            found.update(collect_placeholders(item))
    elif isinstance(value, dict):
        for item in value.values():
            found.update(collect_placeholders(item))
    return found


def validate_command(command: dict[str, Any], label: str, issues: list[str]) -> None:
    if not isinstance(command.get("id"), str) or not str(command.get("id")).strip():
        issues.append(f"{label}.id must be a non-empty string")
    kind = command_kind(command)
    if kind is None:
        issues.append(f"{label} must define exactly one of argv, script, or builtin")
    if kind == "argv":
        argv = command.get("argv")
        if not isinstance(argv, list) or not argv or not all(isinstance(item, str) for item in argv):
            issues.append(f"{label}.argv must be a non-empty list of strings")
    if kind == "script" and not isinstance(command.get("script"), str):
        issues.append(f"{label}.script must be a string")
    if kind == "builtin" and command.get("builtin") not in {"source_status", "ai_scientist"}:
        issues.append(f"{label}.builtin is invalid")
    if "cwd" in command and not isinstance(command.get("cwd"), str):
        issues.append(f"{label}.cwd must be a string")
    if "env" in command:
        env = require_mapping(command.get("env"), f"{label}.env", issues)
        for key, value in env.items():
            if not isinstance(key, str) or not isinstance(value, str):
                issues.append(f"{label}.env entries must be string:string")
    if "timeout_seconds" in command and (
        not isinstance(command.get("timeout_seconds"), int) or int(command.get("timeout_seconds")) <= 0
    ):
        issues.append(f"{label}.timeout_seconds must be a positive integer")
    if "artifacts" in command:
        artifacts = require_list(command.get("artifacts"), f"{label}.artifacts", issues)
        for idx, pattern in enumerate(artifacts):
            if not isinstance(pattern, str) or not pattern:
                issues.append(f"{label}.artifacts[{idx}] must be a non-empty string")
    for placeholder in sorted(collect_placeholders(command) - ALLOWED_PLACEHOLDERS):
        issues.append(f"{label} uses unknown placeholder {{{placeholder}}}")


def validate_task_manifest(task_id: str, manifest: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    if manifest.get("schema_version") != TASK_SCHEMA:
        issues.append(f"schema_version must be {TASK_SCHEMA}")
    if manifest.get("task_id") != task_id:
        issues.append(f"task_id must match directory name: {task_id}")
    for key in ("title", "status", "goal"):
        if not isinstance(manifest.get(key), str) or not str(manifest.get(key)).strip():
            issues.append(f"{key} must be a non-empty string")
    metric = require_mapping(manifest.get("metric"), "metric", issues)
    if not isinstance(metric.get("name"), str) or not metric.get("name"):
        issues.append("metric.name must be a non-empty string")
    if metric.get("direction") not in {"maximize", "minimize"}:
        issues.append("metric.direction must be maximize or minimize")
    observability = require_mapping(manifest.get("observability"), "observability", issues)
    if observability.get("provider") != "wandb_weave":
        issues.append("observability.provider must be wandb_weave")
    return issues


def validate_loop_spec(task_id: str, spec: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    if spec.get("schema_version") != LOOP_SCHEMA:
        issues.append(f"schema_version must be {LOOP_SCHEMA}")
    if spec.get("task_id") != task_id:
        issues.append(f"task_id must match directory name: {task_id}")
    loop = require_mapping(spec.get("loop"), "loop", issues)
    if loop.get("mode") not in {"continuous", "manual"}:
        issues.append("loop.mode must be continuous or manual")
    for key in ("sleep_seconds", "max_cycles", "max_wall_minutes"):
        if key in loop and (not isinstance(loop.get(key), int) or int(loop.get(key)) < 0):
            issues.append(f"loop.{key} must be a non-negative integer")
    if "stop_file" in loop and not isinstance(loop.get("stop_file"), str):
        issues.append("loop.stop_file must be a string")
    for idx, gate_obj in enumerate(require_list(spec.get("source_gates", []), "source_gates", issues)):
        gate = require_mapping(gate_obj, f"source_gates[{idx}]", issues)
        if not isinstance(gate.get("source_id"), str) or not str(gate.get("source_id")).strip():
            issues.append(f"source_gates[{idx}].source_id must be a non-empty string")
        if gate.get("head_policy") not in {"require_registered_ref", "warn_registered_ref", "ignore_registered_ref"}:
            issues.append(f"source_gates[{idx}].head_policy is invalid")
        if "tracked_clean" in gate and not isinstance(gate.get("tracked_clean"), bool):
            issues.append(f"source_gates[{idx}].tracked_clean must be a boolean")
        if "allow_untracked" in gate:
            require_list(gate.get("allow_untracked"), f"source_gates[{idx}].allow_untracked", issues)
    commands = require_mapping(spec.get("commands"), "commands", issues)
    for group in ("preflight", "cycle", "agent"):
        entries = require_list(commands.get(group, []), f"commands.{group}", issues)
        for idx, command_obj in enumerate(entries):
            command = require_mapping(command_obj, f"commands.{group}[{idx}]", issues)
            validate_command(command, f"commands.{group}[{idx}]", issues)
            if command.get("builtin") == "ai_scientist" and group != "agent":
                issues.append(f"commands.{group}[{idx}].builtin ai_scientist is only allowed in commands.agent")
    return issues


def validate_task_memory(task_id: str) -> list[str]:
    issues: list[str] = []
    memory = task_memory_dir(task_id)
    if not memory.exists():
        return issues
    for filename, (schema, field) in TASK_MEMORY_SCHEMAS.items():
        path = memory / filename
        if not path.exists():
            continue
        data = load_yaml_file(path)
        if data.get("schema_version") != schema:
            issues.append(f"{rel_display(path)} schema_version must be {schema}")
        if data.get("task_id") != task_id:
            issues.append(f"{rel_display(path)} task_id must be {task_id}")
        if not isinstance(data.get(field), list):
            issues.append(f"{rel_display(path)} {field} must be a list")
    return issues


def validate_run_files(task_id: str, run_id: str) -> list[str]:
    issues: list[str] = []
    run_dir = task_run_dir(task_id, run_id)
    run = read_json_file(run_dir / "run.json")
    if run.get("schema_version") != RUN_SCHEMA:
        issues.append(f"{rel_display(run_dir / 'run.json')} schema_version must be {RUN_SCHEMA}")
    if run.get("task_id") != task_id:
        issues.append(f"{rel_display(run_dir / 'run.json')} task_id must be {task_id}")
    if run.get("run_id") != run_id:
        issues.append(f"{rel_display(run_dir / 'run.json')} run_id must be {run_id}")
    for path, schema in [
        (run_dir / "observations.jsonl", OBSERVATION_SCHEMA),
        (run_dir / "artifacts.jsonl", ARTIFACT_SCHEMA),
    ]:
        for idx, row in enumerate(read_jsonl(path), start=1):
            if row.get("schema_version") != schema:
                issues.append(f"{rel_display(path)} row {idx} schema_version must be {schema}")
            if row.get("task_id") != task_id:
                issues.append(f"{rel_display(path)} row {idx} task_id must be {task_id}")
            if row.get("run_id") != run_id:
                issues.append(f"{rel_display(path)} row {idx} run_id must be {run_id}")
    return issues


def cmd_task_validate(args: argparse.Namespace) -> None:
    targets = active_task_ids() if args.all else [safe_id(args.task_id, "task_id")]
    failed = False
    for task_id in targets:
        manifest_path = task_manifest_path(task_id)
        loop_path = task_loop_path(task_id)
        issues: list[str] = []
        if not manifest_path.exists():
            issues.append(f"missing task manifest: {manifest_path.relative_to(ROOT)}")
        else:
            issues.extend(validate_task_manifest(task_id, load_yaml_file(manifest_path)))
        if not loop_path.exists():
            issues.append(f"missing loop spec: {loop_path.relative_to(ROOT)}")
        else:
            issues.extend(validate_loop_spec(task_id, load_yaml_file(loop_path)))
        issues.extend(validate_task_memory(task_id))
        if issues:
            failed = True
            print(f"{task_id}: invalid")
            for issue in issues:
                print(f"- {issue}")
        else:
            print(f"{task_id}: valid")
    if failed:
        raise SystemExit(1)


def active_task_ids() -> list[str]:
    if not TASKS.exists():
        return []
    ids: list[str] = []
    for path in sorted(item for item in TASKS.iterdir() if item.is_dir()):
        manifest = path / "task.yaml"
        if manifest.exists() and read_yaml_scalar(manifest, "status") == "active":
            ids.append(path.name)
    return ids


def rel_display(path: Path) -> str:
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return str(path)


def metric_text(manifest: dict[str, Any]) -> str:
    metric = manifest.get("metric", {})
    if not isinstance(metric, dict):
        return "not declared"
    name = str(metric.get("name") or "not declared")
    direction = str(metric.get("direction") or "unknown")
    return f"`{name}`, {direction}"


def observability_text(config: dict[str, Any]) -> str:
    observability = config.get("observability", {})
    if not isinstance(observability, dict):
        return "not configured"
    provider = str(observability.get("provider") or "not configured")
    entity = str(observability.get("entity") or "")
    project = str(observability.get("project") or "")
    required = "required" if observability.get("required") else "optional"
    target = f" `{entity}/{project}`" if entity and project else ""
    return f"{provider}{target}, {required}"


def task_sources_text(manifest: dict[str, Any]) -> str:
    sources = manifest.get("sources", [])
    if not isinstance(sources, list) or not sources:
        return "none declared"
    source_ids: list[str] = []
    for entry in sources:
        if isinstance(entry, dict) and isinstance(entry.get("source_id"), str):
            source_ids.append(f"`{entry['source_id']}`")
    return ", ".join(source_ids) if source_ids else "none declared"


def task_dirs(task_id: str) -> list[str]:
    return [
        f"tasks/{task_id}/bin/",
        f"tasks/{task_id}/memory/",
        f"tasks/{task_id}/code/",
        f"tasks/{task_id}/results/",
        f"tasks/{task_id}/plots/",
        f"tasks/{task_id}/reports/",
        f"tasks/{task_id}/runs/",
        f"tasks/{task_id}/assets/",
    ]


def render_task_status(task_id: str) -> str:
    manifest = load_yaml_file(task_manifest_path(task_id))
    loop = load_yaml_file(task_loop_path(task_id))
    title = str(manifest.get("title") or task_id)
    loop_cfg = loop.get("loop", {}) if isinstance(loop.get("loop"), dict) else {}
    max_cycles = loop_cfg.get("max_cycles", "not set")
    max_wall = loop_cfg.get("max_wall_minutes", "not set")
    source_refs = task_sources_text(manifest)
    curated_assets = manifest.get("curated_assets", [])
    curated_state = "none tracked" if not curated_assets else ", ".join(str(item) for item in curated_assets)
    return f"""# {title} Current State

Status: {manifest.get("status", "unknown")}
Metric: {metric_text(manifest)}
Sources: {source_refs}
Curated assets: {curated_state}

## Goal

{manifest.get("goal", "")}

## Loop

- Mode: `{loop_cfg.get("mode", "unknown")}`
- Max cycles: `{max_cycles}`
- Max wall minutes: `{max_wall}`
- Stop file: `{loop_cfg.get("stop_file", "STOP")}`

## Clean Start

No experiment code, results, plots, reports, or run logs are tracked in repo Git. Task artifact directories are local experiment workspaces and may contain ignored logs between runs.

## Workspace

""" + "\n".join(f"- `{item}`" for item in task_dirs(task_id)) + "\n"


def cmd_task_status(args: argparse.Namespace) -> None:
    task_id = safe_id(args.task_id, "task_id")
    if not task_manifest_path(task_id).exists():
        raise SystemExit(f"Task not found: {task_id}")
    print(render_task_status(task_id))


def redact_env(env: dict[str, str]) -> dict[str, str]:
    return {key: "[REDACTED]" if SECRET_ENV_RE.search(key) else value for key, value in env.items()}


def render_placeholders(value: Any, context: dict[str, str]) -> Any:
    if isinstance(value, str):
        rendered = value
        for key, replacement in context.items():
            rendered = rendered.replace("{" + key + "}", replacement)
        return rendered
    if isinstance(value, list):
        return [render_placeholders(item, context) for item in value]
    if isinstance(value, dict):
        return {str(key): render_placeholders(val, context) for key, val in value.items()}
    return value


def append_event(run_dir: Path, event: dict[str, Any]) -> None:
    event = {"time": now_iso(), **event}
    with (run_dir / "events.jsonl").open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, sort_keys=True) + "\n")


def read_events(run_dir: Path) -> list[dict[str, Any]]:
    events = run_dir / "events.jsonl"
    if not events.exists():
        return []
    rows: list[dict[str, Any]] = []
    for line in events.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(event, dict):
            rows.append(event)
    return rows


def source_snapshots(manifest: dict[str, Any]) -> list[dict[str, Any]]:
    snapshots: list[dict[str, Any]] = []
    sources = manifest.get("sources", [])
    if not isinstance(sources, list):
        return snapshots
    for entry in sources:
        if not isinstance(entry, dict) or not isinstance(entry.get("source_id"), str):
            continue
        source_id = str(entry["source_id"])
        snapshot: dict[str, Any] = {
            "source_id": source_id,
            "purpose": entry.get("purpose"),
            "status": "unknown",
        }
        try:
            source = get_source(source_id)
            path = source_path(source)
            snapshot.update(
                {
                    "title": source.get("title"),
                    "remote_url": source.get("remote_url"),
                    "registered_ref": source.get("git_ref"),
                    "materialized_path": str(path),
                }
            )
            if path.exists():
                head = run_git(path, "rev-parse", "HEAD", check=False)
                status = run_git(path, "status", "--short", check=False)
                snapshot.update(
                    {
                        "status": "present",
                        "head": head.stdout.strip() if head.returncode == 0 else "unknown",
                        "working_tree": "clean" if not status.stdout.strip() else "dirty",
                    }
                )
            else:
                snapshot["status"] = "missing"
        except SystemExit as exc:
            snapshot.update({"status": "error", "error": str(exc)})
        snapshots.append(snapshot)
    return snapshots


def write_run_metadata(
    run_dir: Path,
    *,
    task_id: str,
    run_id: str,
    status: str,
    manifest: dict[str, Any],
    spec: dict[str, Any],
    wandb_url: str | None,
) -> None:
    existing = read_json_file(run_dir / "run.json")
    now = now_iso()
    loop_cfg = spec.get("loop", {}) if isinstance(spec.get("loop"), dict) else {}
    data: dict[str, Any] = {
        "schema_version": RUN_SCHEMA,
        "task_id": task_id,
        "run_id": run_id,
        "status": status,
        "started_at": existing.get("started_at") or now,
        "updated_at": now,
        "finished_at": now if status in {"completed", "failed"} else existing.get("finished_at"),
        "wandb_url": wandb_url,
        "metric": manifest.get("metric"),
        "loop": {
            "mode": loop_cfg.get("mode"),
            "max_cycles": loop_cfg.get("max_cycles"),
            "max_wall_minutes": loop_cfg.get("max_wall_minutes"),
            "stop_file": loop_cfg.get("stop_file", "STOP"),
        },
        "source_refs": source_snapshots(manifest),
        "files": {
            "events": "events.jsonl",
            "observations": "observations.jsonl",
            "artifacts": "artifacts.jsonl",
            "summary": "run-summary.md",
            "loop_snapshot": "loop.snapshot.yaml",
            "commands": "commands/",
        },
    }
    write_json_file(run_dir / "run.json", data)


def append_artifact_records(
    run_dir: Path,
    *,
    task_id: str,
    run_id: str,
    group: str,
    cycle: int,
    command_id: str,
    artifacts: list[dict[str, Any]],
) -> None:
    for idx, artifact in enumerate(artifacts):
        matches = artifact.get("matches")
        if not isinstance(matches, list):
            matches = []
        record = {
            "schema_version": ARTIFACT_SCHEMA,
            "artifact_id": f"cycle-{cycle}-{group}-{command_id}-{idx}",
            "task_id": task_id,
            "run_id": run_id,
            "time": now_iso(),
            "cycle": cycle,
            "group": group,
            "command_id": command_id,
            "artifact_type": "declared_command_artifact",
            "pattern": artifact.get("pattern"),
            "present": bool(artifact.get("present")),
            "matches": [rel_to_run(run_dir, str(item)) for item in matches],
        }
        append_jsonl(run_dir / "artifacts.jsonl", record)


def markdown_section(text: str, heading: str) -> str:
    pattern = re.compile(rf"^## {re.escape(heading)}\n(.*?)(?=^## |\Z)", re.MULTILINE | re.DOTALL)
    match = pattern.search(text)
    return match.group(1).strip() if match else ""


def meaningful_summary_text(value: str) -> bool:
    clean = value.strip().lower()
    return bool(clean) and clean not in {"pending agent update.", "pending agent update", "not recorded yet."}


def sync_observation_from_summary(run_dir: Path, task_id: str, run_id: str) -> dict[str, Any] | None:
    summary = run_dir / "run-summary.md"
    if not summary.exists():
        return None
    text = summary.read_text(encoding="utf-8")
    observation = markdown_section(text, "Observation")
    next_action = markdown_section(text, "Next Action")
    if not meaningful_summary_text(observation):
        return None
    record = {
        "schema_version": OBSERVATION_SCHEMA,
        "observation_id": f"summary-{run_id}",
        "task_id": task_id,
        "run_id": run_id,
        "created_at": now_iso(),
        "source": "run_summary",
        "claim": observation,
        "evidence": [f"run:{run_id}/run-summary.md#observation"],
        "confidence": "unrated",
        "metric_impact": "not recorded",
        "decision": "review",
        "next_action": next_action if meaningful_summary_text(next_action) else "",
    }
    upsert_jsonl(run_dir / "observations.jsonl", "observation_id", record)
    return record


def untracked_allowed(path: str, patterns: list[str]) -> bool:
    clean = path.rstrip("/")
    for pattern in patterns:
        pat = pattern.rstrip("/")
        if pattern.endswith("/") and (clean == pat or clean.startswith(pat + "/")):
            return True
        if fnmatch.fnmatch(clean, pat) or fnmatch.fnmatch(clean + "/", pattern):
            return True
    return False


def check_source_gate(gate: dict[str, Any], *, strict: bool, run_dir: Path | None = None) -> None:
    source_id = str(gate["source_id"])
    source = get_source(source_id)
    path = source_path(source)
    if not path.exists():
        raise SystemExit(f"Source gate failed for {source_id}: materialized path missing: {path}")
    expected = str(source.get("git_ref") or "")
    head = run_git(path, "rev-parse", "HEAD", check=False)
    current = head.stdout.strip() if head.returncode == 0 else ""
    head_policy = str(gate.get("head_policy") or "require_registered_ref")
    head_matches = bool(expected and current.startswith(expected))
    if head_policy == "require_registered_ref" and not head_matches:
        raise SystemExit(f"Source gate failed for {source_id}: HEAD {current or 'unknown'} does not match {expected}")
    if head_policy == "warn_registered_ref" and not head_matches:
        message = f"Source gate warning for {source_id}: HEAD {current or 'unknown'} does not match {expected}"
        print(message)
        if run_dir is not None:
            append_event(run_dir, {"event": "source_gate_warning", "source_id": source_id, "message": message})
    if bool(gate.get("tracked_clean", False)):
        tracked = run_git(path, "status", "--short", "--untracked-files=no", check=False).stdout.strip()
        if tracked:
            raise SystemExit(f"Source gate failed for {source_id}: tracked files are dirty:\n{tracked}")
    else:
        tracked = ""
    patterns = [str(item) for item in gate.get("allow_untracked", []) if isinstance(item, str)]
    full_status = run_git(path, "status", "--short", check=False).stdout.splitlines()
    disallowed = [line[3:] for line in full_status if line.startswith("?? ") and not untracked_allowed(line[3:], patterns)]
    if disallowed:
        label = "failed" if strict else "warning"
        message = f"Source gate {label} for {source_id}: disallowed untracked paths: {', '.join(disallowed)}"
        if strict:
            raise SystemExit(message)
        print(message)
        if run_dir is not None:
            append_event(run_dir, {"event": "source_gate_warning", "source_id": source_id, "message": message})
    if run_dir is not None:
        append_event(
            run_dir,
            {
                "event": "source_gate_pass",
                "source_id": source_id,
                "path": str(path),
                "head": current or "unknown",
                "registered_ref": expected,
                "head_policy": head_policy,
                "tracked_clean_required": bool(gate.get("tracked_clean", False)),
                "tracked_dirty": bool(tracked),
                "allow_untracked": patterns,
            },
        )


def command_display(command: dict[str, Any], context: dict[str, str]) -> str:
    rendered = render_placeholders(command, context)
    if isinstance(rendered, dict) and "argv" in rendered:
        return " ".join(str(item) for item in rendered["argv"])
    if isinstance(rendered, dict) and "script" in rendered:
        return str(rendered["script"])
    if isinstance(rendered, dict) and "builtin" in rendered:
        args = rendered.get("args", [])
        arg_text = " ".join(str(item) for item in args) if isinstance(args, list) else ""
        return f"builtin:{rendered['builtin']} {arg_text}".strip()
    return "<invalid command>"


def collect_declared_artifacts(command: dict[str, Any]) -> list[dict[str, Any]]:
    artifact_patterns = command.get("artifacts", [])
    if not isinstance(artifact_patterns, list):
        return []
    artifacts: list[dict[str, Any]] = []
    for pattern in artifact_patterns:
        if not isinstance(pattern, str) or not pattern:
            continue
        matches = sorted(glob.glob(pattern))
        artifacts.append({"pattern": pattern, "present": bool(matches), "matches": matches})
    return artifacts


def run_source_status_builtin(args: list[str]) -> tuple[int, str, str]:
    if len(args) != 1:
        return 2, "", "source_status requires exactly one source_id"
    out = io.StringIO()
    err = io.StringIO()
    code = 0
    with contextlib.redirect_stdout(out), contextlib.redirect_stderr(err):
        try:
            cmd_source_status(argparse.Namespace(source_id=args[0]))
        except SystemExit as exc:
            code = int(exc.code) if isinstance(exc.code, int) else 1
    return code, out.getvalue(), err.getvalue()


def ai_scientist_prompt(task_id: str, run_id: str, cycle: int) -> str:
    task = task_dir(task_id)
    scientist = task / "scientist.md"
    if not scientist.exists():
        raise SystemExit(f"Scientist instructions not found: {scientist}")
    run_dir = task / "runs" / run_id
    return (
        "Use the account agent setup. Read ~/ai-lab/policies/development-policy.md. "
        f"Read {scientist}. Current run directory: {run_dir}. "
        f"Task: {task_id}. Run ID: {run_id}. Cycle: {cycle}. "
        "Execute the task-local AI scientist loop exactly and then stop."
    )


def run_ai_scientist_builtin(task_id: str, run_id: str, cycle: int, timeout: int) -> subprocess.CompletedProcess[str]:
    prompt = ai_scientist_prompt(task_id, run_id, cycle)
    return subprocess.run(
        [str(ROOT / "bin" / "codex-lab"), prompt],
        cwd=str(ROOT.parent),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        timeout=timeout,
        check=False,
    )


def subprocess_text(data: str | bytes | None) -> str:
    if data is None:
        return ""
    if isinstance(data, bytes):
        return data.decode("utf-8", errors="replace")
    return data


class Observability:
    def __init__(self, task_id: str, run_id: str, dry_run: bool, disabled: bool = False):
        self.task_id = task_id
        self.run_id = run_id
        self.disabled = dry_run or disabled or os.environ.get("AI_LAB_DISABLE_WANDB") == "1"
        self.wandb_run: Any | None = None
        self.weave_event: Any | None = None
        self.url: str | None = None
        self.config = load_lab_config().get("observability", {})
        if not isinstance(self.config, dict):
            self.config = {}

    def _has_credentials(self) -> bool:
        if os.environ.get("WANDB_API_KEY"):
            return True
        try:
            auth = netrc.netrc().authenticators("api.wandb.ai") or netrc.netrc().authenticators("wandb.ai")
            return bool(auth and auth[2])
        except (FileNotFoundError, netrc.NetrcParseError, OSError):
            return False

    def start(self, metadata: dict[str, Any]) -> None:
        if self.disabled:
            return
        if self.config.get("provider") != "wandb_weave":
            raise SystemExit("lab.yaml observability.provider must be wandb_weave for normal runs.")
        if self.config.get("required", False) and not self._has_credentials():
            raise SystemExit(
                "W&B observability is required. Run `wandb login` or set WANDB_API_KEY, "
                "or use --dry-run / AI_LAB_DISABLE_WANDB=1 for tests."
            )
        try:
            import wandb  # type: ignore
            import weave  # type: ignore
        except ModuleNotFoundError as exc:
            raise SystemExit("W&B observability requires `wandb` and `weave` dependencies.") from exc
        entity = str(self.config.get("entity") or "")
        project = str(self.config.get("project") or "")
        if not entity or not project:
            raise SystemExit("lab.yaml must set observability.entity and observability.project.")
        self.wandb_run = wandb.init(
            entity=entity,
            project=project,
            name=self.run_id,
            job_type="ai-scientist",
            config=metadata,
        )
        self.url = getattr(self.wandb_run, "url", None)
        weave.init(f"{entity}/{project}")

        @weave.op(name="ai_lab_event")
        def _record_event(event: dict[str, Any]) -> dict[str, Any]:
            return event

        self.weave_event = _record_event

    def log(self, event: dict[str, Any]) -> None:
        if self.disabled:
            return
        payload = {"time": now_iso(), "task_id": self.task_id, "run_id": self.run_id, **event}
        if self.wandb_run is not None:
            scalars = {
                key: value
                for key, value in payload.items()
                if key != "event" and (isinstance(value, (int, float, str, bool)) or value is None)
            }
            self.wandb_run.log({"event_payload": payload, "event_name": payload.get("event"), **scalars})
        if self.weave_event is not None:
            self.weave_event(payload)

    def finish(self, status: str) -> None:
        if self.disabled:
            return
        self.log({"event": "observability_finish", "status": status})
        if self.wandb_run is not None:
            self.wandb_run.finish(exit_code=0 if status == "completed" else 1)


def rel_to_run(run_dir: Path, path: str) -> str:
    try:
        return str(Path(path).resolve().relative_to(run_dir.resolve()))
    except (OSError, ValueError):
        return path


def event_key(event: dict[str, Any]) -> tuple[str, str, str]:
    return (str(event.get("cycle") or ""), str(event.get("group") or ""), str(event.get("command_id") or ""))


def render_source_snapshot(events: list[dict[str, Any]]) -> str:
    source_events = [event for event in events if event.get("event") in {"source_gate_pass", "source_gate_warning"}]
    if not source_events:
        return "Not recorded yet."
    rows = ["| Source | State | HEAD | Registered ref | Notes |", "| --- | --- | --- | --- | --- |"]
    for event in source_events:
        state = "warning" if event.get("event") == "source_gate_warning" else "pass"
        source_id = str(event.get("source_id") or "unknown")
        head = str(event.get("head") or "")
        registered = str(event.get("registered_ref") or "")
        notes = str(event.get("message") or "")
        if not notes and event.get("tracked_clean_required"):
            notes = "tracked files clean"
        rows.append(f"| `{source_id}` | {state} | `{head}` | `{registered}` | {notes or '-'} |")
    return "\n".join(rows)


def command_events(events: list[dict[str, Any]]) -> list[dict[str, Any]]:
    starts = {event_key(event): event for event in events if event.get("event") == "command_start"}
    rows: list[dict[str, Any]] = []
    for event in events:
        if event.get("event") != "command_finish":
            continue
        start = starts.get(event_key(event), {})
        rows.append({**start, **event})
    return rows


def render_command_table(events: list[dict[str, Any]], *, group: str | None = None) -> str:
    commands = command_events(events)
    if group is not None:
        commands = [event for event in commands if event.get("group") == group]
    if not commands:
        return "No commands finished yet."
    rows = ["| Cycle | Group | Command | Code | Duration | Logs |", "| --- | --- | --- | --- | --- | --- |"]
    for event in commands:
        stdout = str(event.get("stdout_path") or "")
        stderr = str(event.get("stderr_path") or "")
        logs = ", ".join(f"`{item}`" for item in [stdout, stderr] if item) or "-"
        duration = event.get("duration_seconds")
        duration_text = f"{duration}s" if duration is not None else "-"
        rows.append(
            "| {cycle} | {group} | `{command_id}` | {returncode} | {duration} | {logs} |".format(
                cycle=event.get("cycle", "-"),
                group=event.get("group", "-"),
                command_id=event.get("command_id", "-"),
                returncode=event.get("returncode", "-"),
                duration=duration_text,
                logs=logs,
            )
        )
    return "\n".join(rows)


def render_artifact_table(run_dir: Path, events: list[dict[str, Any]]) -> str:
    artifact_rows: list[str] = []
    for event in events:
        if event.get("event") != "command_finish":
            continue
        artifacts = event.get("artifacts")
        if not isinstance(artifacts, list):
            continue
        for artifact in artifacts:
            if not isinstance(artifact, dict):
                continue
            matches = artifact.get("matches")
            if not isinstance(matches, list):
                matches = []
            artifact_rows.append(
                "| `{command_id}` | `{pattern}` | {present} | {matches} |".format(
                    command_id=event.get("command_id", "-"),
                    pattern=artifact.get("pattern", "-"),
                    present="yes" if artifact.get("present") else "no",
                    matches=", ".join(f"`{rel_to_run(run_dir, str(item))}`" for item in matches) or "-",
                )
            )
    if not artifact_rows:
        return "No declared artifacts recorded yet."
    return "\n".join(["| Command | Pattern | Present | Matches |", "| --- | --- | --- | --- |", *artifact_rows])


def replace_section(text: str, heading: str, body: str) -> str:
    pattern = re.compile(rf"(^## {re.escape(heading)}\n)(.*?)(?=^## |\Z)", re.MULTILINE | re.DOTALL)
    replacement = f"## {heading}\n\n{body.rstrip()}\n\n"
    if pattern.search(text):
        return pattern.sub(replacement, text, count=1)
    return text.rstrip() + "\n\n" + replacement


def write_run_summary(run_dir: Path, task_id: str, status: str, wandb_url: str | None) -> None:
    if run_dir.joinpath("run-summary.md").exists():
        return
    run_dir.joinpath("run-summary.md").write_text(
        f"""# AI Scientist Run: {task_id}

Run ID: {run_dir.name}
Status: {status}
Started: {now_iso()}
Finished: pending
W&B: {wandb_url or "not started"}

## Source Snapshot

Not recorded yet.

## Preflight

No preflight commands finished yet.

## Command Log

No commands finished yet.

## Declared Artifacts

No declared artifacts recorded yet.

## Agent Output

No agent command finished yet.

## Observation

Pending agent update.

## Next Action

Pending agent update.

## Files

- Events: `events.jsonl`
- Command logs: `commands/`
- Loop snapshot: `loop.snapshot.yaml`
""",
        encoding="utf-8",
    )


def update_run_summary(run_dir: Path, status: str, wandb_url: str | None = None) -> None:
    summary = run_dir / "run-summary.md"
    if not summary.exists():
        return
    events = read_events(run_dir)
    text = summary.read_text(encoding="utf-8")
    text = re.sub(r"^Status:\s*.*$", f"Status: {status}", text, count=1, flags=re.MULTILINE)
    if wandb_url:
        text = re.sub(r"^W&B:\s*.*$", f"W&B: {wandb_url}", text, count=1, flags=re.MULTILINE)
    finished = "pending" if status == "running" else now_iso()
    if re.search(r"^Finished:\s*.*$", text, flags=re.MULTILINE):
        text = re.sub(r"^Finished:\s*.*$", f"Finished: {finished}", text, count=1, flags=re.MULTILINE)
    else:
        text = re.sub(r"^(Started:\s*.*)$", rf"\1{chr(10)}Finished: {finished}", text, count=1, flags=re.MULTILINE)
    text = replace_section(text, "Source Snapshot", render_source_snapshot(events))
    text = replace_section(text, "Preflight", render_command_table(events, group="preflight"))
    text = replace_section(text, "Command Log", render_command_table(events))
    text = replace_section(text, "Declared Artifacts", render_artifact_table(run_dir, events))
    text = replace_section(text, "Agent Output", render_command_table(events, group="agent"))
    summary.write_text(text, encoding="utf-8")


def run_command(
    command: dict[str, Any],
    *,
    group: str,
    context: dict[str, str],
    run_dir: Path,
    dry_run: bool,
    observability: Observability,
    deadline_epoch: float | None = None,
) -> int:
    rendered_obj = render_placeholders(command, context)
    if not isinstance(rendered_obj, dict):
        raise SystemExit("Rendered command is invalid.")
    command_id = str(rendered_obj.get("id") or "command")
    cycle = int(context["cycle"])
    display = command_display(command, context)
    print(f"[{group}] {command_id}: {display}")
    if dry_run:
        return 0
    timeout = int(rendered_obj.get("timeout_seconds") or 3600)
    if deadline_epoch is not None:
        remaining = int(deadline_epoch - time.time())
        if remaining <= 0:
            append_event(run_dir, {"event": "command_skipped", "group": group, "cycle": cycle, "command_id": command_id})
            observability.log({"event": "command_skipped", "group": group, "cycle": cycle, "command_id": command_id})
            return 124
        timeout = min(timeout, max(1, remaining))
    logs = run_dir / "commands"
    logs.mkdir(parents=True, exist_ok=True)
    base = logs / f"cycle-{cycle}-{group}-{command_id}"
    started = time.time()
    start_event = {
        "event": "command_start",
        "group": group,
        "cycle": cycle,
        "command_id": command_id,
        "command": display,
        "cwd": rendered_obj.get("cwd"),
        "env": redact_env(rendered_obj.get("env", {}) if isinstance(rendered_obj.get("env"), dict) else {}),
    }
    append_event(run_dir, start_event)
    observability.log(start_event)
    try:
        if "builtin" in rendered_obj:
            builtin = str(rendered_obj["builtin"])
            args = [str(item) for item in rendered_obj.get("args", [])] if isinstance(rendered_obj.get("args", []), list) else []
            if builtin == "source_status":
                code, stdout, stderr = run_source_status_builtin(args)
                result = subprocess.CompletedProcess(["builtin", builtin, *args], code, stdout, stderr)
            elif builtin == "ai_scientist":
                prompt = ai_scientist_prompt(context["task_id"], context["run_id"], cycle)
                observability.log({"event": "agent_prompt", "cycle": cycle, "prompt": prompt})
                result = run_ai_scientist_builtin(context["task_id"], context["run_id"], cycle, timeout)
            else:
                raise SystemExit(f"Unknown builtin: {builtin}")
        elif "argv" in rendered_obj:
            argv = [str(item) for item in rendered_obj["argv"]]
            cwd = Path(str(rendered_obj.get("cwd") or ROOT)).expanduser()
            env = os.environ.copy()
            if isinstance(rendered_obj.get("env"), dict):
                env.update({str(key): str(value) for key, value in rendered_obj["env"].items()})
            result = subprocess.run(
                argv,
                cwd=str(cwd),
                env=env,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=timeout,
                check=False,
            )
        elif "script" in rendered_obj:
            script_path = Path(str(rendered_obj["script"])).expanduser()
            if not script_path.is_absolute():
                script_path = Path(context["task_dir"]) / script_path
            cwd = Path(str(rendered_obj.get("cwd") or script_path.parent)).expanduser()
            result = subprocess.run([str(script_path)], cwd=str(cwd), text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout, check=False)
        else:
            raise SystemExit(f"Command has no executable body: {command_id}")
    except subprocess.TimeoutExpired as exc:
        stdout = subprocess_text(exc.stdout)
        stderr = subprocess_text(exc.stderr) or f"timeout after {timeout}s"
        base.with_suffix(".stdout.log").write_text(stdout, encoding="utf-8")
        base.with_suffix(".stderr.log").write_text(stderr, encoding="utf-8")
        artifacts = collect_declared_artifacts(rendered_obj)
        event = {
            "event": "command_finish",
            "group": group,
            "cycle": cycle,
            "command_id": command_id,
            "returncode": 124,
            "artifacts": artifacts,
        }
        append_event(run_dir, event)
        append_artifact_records(
            run_dir,
            task_id=context["task_id"],
            run_id=context["run_id"],
            group=group,
            cycle=cycle,
            command_id=command_id,
            artifacts=artifacts,
        )
        update_run_summary(run_dir, "running")
        observability.log({**event, "stdout": stdout, "stderr": stderr})
        return 124
    stdout = result.stdout or ""
    stderr = result.stderr or ""
    base.with_suffix(".stdout.log").write_text(stdout, encoding="utf-8")
    base.with_suffix(".stderr.log").write_text(stderr, encoding="utf-8")
    artifacts = collect_declared_artifacts(rendered_obj)
    event = {
        "event": "command_finish",
        "group": group,
        "cycle": cycle,
        "command_id": command_id,
        "returncode": result.returncode,
        "duration_seconds": round(time.time() - started, 3),
        "stdout_path": str(base.with_suffix(".stdout.log").relative_to(run_dir)),
        "stderr_path": str(base.with_suffix(".stderr.log").relative_to(run_dir)),
        "artifacts": artifacts,
        "stdout": stdout[-20000:],
        "stderr": stderr[-20000:],
    }
    append_event(run_dir, {key: value for key, value in event.items() if key not in {"stdout", "stderr"}})
    append_artifact_records(
        run_dir,
        task_id=context["task_id"],
        run_id=context["run_id"],
        group=group,
        cycle=cycle,
        command_id=command_id,
        artifacts=artifacts,
    )
    update_run_summary(run_dir, "running")
    observability.log(event)
    return int(result.returncode)


def cmd_task_run(args: argparse.Namespace) -> None:
    task_id = safe_id(args.task_id, "task_id")
    manifest = load_yaml_file(task_manifest_path(task_id))
    spec_path = task_loop_path(task_id)
    spec = load_yaml_file(spec_path)
    issues = validate_task_manifest(task_id, manifest) + validate_loop_spec(task_id, spec)
    if issues:
        for issue in issues:
            print(f"- {issue}")
        raise SystemExit(1)
    task = task_dir(task_id)
    run_id = args.run_id or f"{task_id}-{timestamp()}"
    run_dir = task / "runs" / run_id
    loop = spec.get("loop", {}) if isinstance(spec.get("loop"), dict) else {}
    max_cycles = 1 if args.once else int(args.max_cycles or loop.get("max_cycles") or 1)
    if args.continuous:
        max_cycles = int(args.max_cycles or loop.get("max_cycles") or 1)
    max_wall_minutes = int(loop.get("max_wall_minutes") or 0)
    sleep_seconds = int(loop.get("sleep_seconds") or 0)
    stop_file = task / str(loop.get("stop_file") or "STOP")
    commands = spec["commands"] if isinstance(spec["commands"], dict) else {}
    preflight = [item for item in commands.get("preflight", []) if isinstance(item, dict)]
    cycle_commands = [item for item in commands.get("cycle", []) if isinstance(item, dict)]
    agent_commands = [item for item in commands.get("agent", []) if isinstance(item, dict)]
    context = {
        "task_id": task_id,
        "run_id": run_id,
        "cycle": "0",
        "run_dir": str(run_dir),
        "task_dir": str(task),
        "root": str(ROOT),
    }
    observability = Observability(task_id, run_id, args.dry_run, disabled=args.no_wandb)
    if args.dry_run:
        print(f"dry_run: {task_id} run_id={run_id}")
    else:
        run_dir.mkdir(parents=True, exist_ok=True)
        (run_dir / "loop.snapshot.yaml").write_text(spec_path.read_text(encoding="utf-8"), encoding="utf-8")
        for stream in ("observations.jsonl", "artifacts.jsonl"):
            (run_dir / stream).touch(exist_ok=True)
        observability.start({"task_id": task_id, "run_id": run_id, "metric": manifest.get("metric")})
        write_run_metadata(run_dir, task_id=task_id, run_id=run_id, status="running", manifest=manifest, spec=spec, wandb_url=observability.url)
        write_run_summary(run_dir, task_id, "running", observability.url)
        event = {"event": "run_start", "task_id": task_id, "run_id": run_id, "wandb_url": observability.url}
        append_event(run_dir, event)
        observability.log(event)
    status = "completed"
    try:
        start = time.time()
        deadline_epoch = start + max_wall_minutes * 60 if max_wall_minutes else None
        for gate_obj in spec.get("source_gates", []) if isinstance(spec.get("source_gates"), list) else []:
            if isinstance(gate_obj, dict):
                check_source_gate(gate_obj, strict=not args.dry_run, run_dir=None if args.dry_run else run_dir)
        for command in preflight:
            code = run_command(command, group="preflight", context=context, run_dir=run_dir, dry_run=args.dry_run, observability=observability, deadline_epoch=deadline_epoch)
            if code != 0:
                raise SystemExit(code)
        for cycle in range(1, max_cycles + 1):
            if stop_file.exists():
                print(f"stop_file present: {stop_file}")
                break
            if max_wall_minutes and (time.time() - start) > max_wall_minutes * 60:
                print(f"max_wall_minutes reached: {max_wall_minutes}")
                break
            context["cycle"] = str(cycle)
            for command in cycle_commands:
                code = run_command(command, group="cycle", context=context, run_dir=run_dir, dry_run=args.dry_run, observability=observability, deadline_epoch=deadline_epoch)
                if code != 0:
                    raise SystemExit(code)
            for command in agent_commands:
                code = run_command(command, group="agent", context=context, run_dir=run_dir, dry_run=args.dry_run, observability=observability, deadline_epoch=deadline_epoch)
                if code != 0:
                    raise SystemExit(code)
            if cycle < max_cycles and sleep_seconds and args.continuous and not args.dry_run:
                time.sleep(sleep_seconds)
    except BaseException as exc:
        status = "failed"
        if not args.dry_run:
            event: dict[str, Any] = {"event": "run_failed", "task_id": task_id, "run_id": run_id, "error_type": type(exc).__name__}
            if isinstance(exc, SystemExit):
                event["returncode"] = exc.code if isinstance(exc.code, int) else 1
            else:
                event["message"] = str(exc)
            append_event(run_dir, event)
            observability.log(event)
            sync_observation_from_summary(run_dir, task_id, run_id)
            write_run_metadata(run_dir, task_id=task_id, run_id=run_id, status="failed", manifest=manifest, spec=spec, wandb_url=observability.url)
            update_run_summary(run_dir, "failed", observability.url)
            observability.finish("failed")
        raise
    else:
        if not args.dry_run:
            event = {"event": "run_finish", "task_id": task_id, "run_id": run_id}
            append_event(run_dir, event)
            observability.log(event)
            sync_observation_from_summary(run_dir, task_id, run_id)
            write_run_metadata(run_dir, task_id=task_id, run_id=run_id, status="completed", manifest=manifest, spec=spec, wandb_url=observability.url)
            update_run_summary(run_dir, "completed", observability.url)
            observability.finish("completed")
    finally:
        if args.dry_run:
            status = "dry_run"
    print(f"run_id: {run_id}")
    if observability.url:
        print(f"wandb: {observability.url}")


def infer_run_status(run_dir: Path) -> str:
    metadata = read_json_file(run_dir / "run.json")
    if isinstance(metadata.get("status"), str):
        return str(metadata["status"])
    status = "running"
    for event in read_events(run_dir):
        if event.get("event") == "run_failed":
            status = "failed"
        elif event.get("event") == "run_finish":
            status = "completed"
    return status


def rebuild_artifacts_from_events(run_dir: Path, task_id: str, run_id: str) -> None:
    rows: list[dict[str, Any]] = []
    for event in read_events(run_dir):
        if event.get("event") != "command_finish":
            continue
        artifacts = event.get("artifacts")
        if not isinstance(artifacts, list):
            continue
        for idx, artifact in enumerate(artifacts):
            if not isinstance(artifact, dict):
                continue
            matches = artifact.get("matches")
            if not isinstance(matches, list):
                matches = []
            cycle = int(event.get("cycle") or 0)
            group = str(event.get("group") or "unknown")
            command_id = str(event.get("command_id") or "unknown")
            rows.append(
                {
                    "schema_version": ARTIFACT_SCHEMA,
                    "artifact_id": f"cycle-{cycle}-{group}-{command_id}-{idx}",
                    "task_id": task_id,
                    "run_id": run_id,
                    "time": str(event.get("time") or now_iso()),
                    "cycle": cycle,
                    "group": group,
                    "command_id": command_id,
                    "artifact_type": "declared_command_artifact",
                    "pattern": artifact.get("pattern"),
                    "present": bool(artifact.get("present")),
                    "matches": [rel_to_run(run_dir, str(item)) for item in matches],
                }
            )
    write_jsonl(run_dir / "artifacts.jsonl", rows)


def cmd_task_summarize(args: argparse.Namespace) -> None:
    task_id = safe_id(args.task_id, "task_id")
    run_id = safe_id(args.run_id, "run_id")
    run_dir = task_run_dir(task_id, run_id)
    if not run_dir.exists():
        raise SystemExit(f"Run not found: {rel_display(run_dir)}")
    manifest = load_yaml_file(task_manifest_path(task_id))
    spec = load_yaml_file(task_loop_path(task_id))
    metadata = read_json_file(run_dir / "run.json")
    wandb_url = str(metadata.get("wandb_url") or "") or None
    if not (run_dir / "run-summary.md").exists():
        write_run_summary(run_dir, task_id, infer_run_status(run_dir), wandb_url)
    rebuild_artifacts_from_events(run_dir, task_id, run_id)
    status = infer_run_status(run_dir)
    update_run_summary(run_dir, status, wandb_url)
    sync_observation_from_summary(run_dir, task_id, run_id)
    write_run_metadata(run_dir, task_id=task_id, run_id=run_id, status=status, manifest=manifest, spec=spec, wandb_url=wandb_url)
    issues = validate_run_files(task_id, run_id)
    if issues:
        for issue in issues:
            print(f"- {issue}")
        raise SystemExit(1)
    print(f"summarized: {rel_display(run_dir)}")


def cmd_agent_prompt(args: argparse.Namespace) -> None:
    print(ai_scientist_prompt(args.task_id, args.run_id, args.cycle))


def task_memory_template(task_id: str, filename: str) -> dict[str, Any]:
    schema, field = TASK_MEMORY_SCHEMAS[filename]
    return {"schema_version": schema, "task_id": task_id, field: []}


def write_yaml_file(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(require_yaml().safe_dump(data, sort_keys=False), encoding="utf-8")


def load_task_memory_file(task_id: str, filename: str) -> dict[str, Any]:
    path = task_memory_dir(task_id) / filename
    if not path.exists():
        return task_memory_template(task_id, filename)
    return load_yaml_file(path)


def write_task_memory_file(task_id: str, filename: str, data: dict[str, Any]) -> None:
    write_yaml_file(task_memory_dir(task_id) / filename, data)


def ensure_task_memory_files(task_id: str) -> None:
    for filename in TASK_MEMORY_SCHEMAS:
        path = task_memory_dir(task_id) / filename
        if not path.exists():
            write_task_memory_file(task_id, filename, task_memory_template(task_id, filename))


def collection_field(filename: str) -> str:
    return TASK_MEMORY_SCHEMAS[filename][1]


def existing_ids(items: list[Any], key: str) -> set[str]:
    return {str(item.get(key)) for item in items if isinstance(item, dict) and item.get(key)}


def upsert_list_item(items: list[Any], key: str, item: dict[str, Any]) -> list[Any]:
    return [entry for entry in items if not (isinstance(entry, dict) and entry.get(key) == item.get(key))] + [item]


def promote_observation(task_id: str, observation: dict[str, Any], status: str) -> str:
    claim = str(observation.get("claim") or "").strip()
    decision = str(observation.get("decision") or "").lower()
    target = "negative-results.yaml" if any(token in decision for token in ("negative", "reject", "fail")) else "insights.yaml"
    field = collection_field(target)
    data = load_task_memory_file(task_id, target)
    items = data.get(field, [])
    if not isinstance(items, list):
        items = []
    run_id = str(observation.get("run_id") or "unknown")
    item_id = f"{field.rstrip('s')}-{run_id}-{len(existing_ids(items, 'id')) + 1}"
    source_id = str(observation.get("observation_id") or item_id)
    if any(isinstance(item, dict) and item.get("source_observation_id") == source_id for item in items):
        return target
    item = {
        "id": item_id,
        "status": status,
        "created_at": today(),
        "source_run": run_id,
        "source_observation_id": source_id,
        "claim": claim,
        "evidence": observation.get("evidence", []),
        "confidence": observation.get("confidence", "unrated"),
        "metric_impact": observation.get("metric_impact", "not recorded"),
        "next_action": observation.get("next_action", ""),
    }
    data[field] = upsert_list_item(items, "id", item)
    write_task_memory_file(task_id, target, data)
    return target


def update_run_memory(task_id: str, run_id: str, status: str) -> None:
    run_dir = task_run_dir(task_id, run_id)
    metadata = read_json_file(run_dir / "run.json")
    observations = read_jsonl(run_dir / "observations.jsonl")
    primary = observations[-1] if observations else {}
    data = load_task_memory_file(task_id, "runs.yaml")
    runs = data.get("runs", [])
    if not isinstance(runs, list):
        runs = []
    data["runs"] = upsert_list_item(
        runs,
        "run_id",
        {
            "run_id": run_id,
            "memory_status": status,
            "run_status": metadata.get("status", infer_run_status(run_dir)),
            "started_at": metadata.get("started_at"),
            "finished_at": metadata.get("finished_at"),
            "wandb_url": metadata.get("wandb_url"),
            "summary": primary.get("claim", ""),
            "next_action": primary.get("next_action", ""),
            "updated_at": today(),
        },
    )
    write_task_memory_file(task_id, "runs.yaml", data)


def cmd_memory_promote(argv: list[str]) -> None:
    parser = argparse.ArgumentParser(prog="ai-lab memory promote", description="Promote a run observation into tracked task memory.")
    parser.add_argument("task_id")
    parser.add_argument("--run-id", required=True)
    parser.add_argument("--status", choices=["draft", "active"], default="draft")
    args = parser.parse_args(argv)
    task_id = safe_id(args.task_id, "task_id")
    run_id = safe_id(args.run_id, "run_id")
    run_dir = task_run_dir(task_id, run_id)
    if not run_dir.exists():
        raise SystemExit(f"Run not found: {rel_display(run_dir)}")
    ensure_task_memory_files(task_id)
    cmd_task_summarize(argparse.Namespace(task_id=task_id, run_id=run_id))
    observations = read_jsonl(run_dir / "observations.jsonl")
    if not observations:
        raise SystemExit(f"No promotable observations found in {rel_display(run_dir / 'observations.jsonl')}")
    touched: set[str] = set()
    for observation in observations:
        if str(observation.get("schema_version")) == OBSERVATION_SCHEMA and str(observation.get("claim") or "").strip():
            touched.add(promote_observation(task_id, observation, str(args.status)))
    update_run_memory(task_id, run_id, str(args.status))
    print("promoted:")
    for filename in sorted(touched | {"runs.yaml"}):
        print(f"- {rel_display(task_memory_dir(task_id) / filename)}")


def cmd_memory(args: argparse.Namespace) -> None:
    if args.memory_args and args.memory_args[0] == "promote":
        cmd_memory_promote(args.memory_args[1:])
        return
    target = ROOT / "bin" / "agent-memory"
    os.execv(str(target), [str(target), *args.memory_args])


def generated_header() -> str:
    return "<!-- Generated by `uv run python bin/ai-lab docs sync`; edit task manifests instead. -->"


def render_docs_index() -> str:
    lab = load_lab_config()
    active = active_task_ids()
    title = str(lab.get("title") or "AI Lab")
    rows = []
    for task_id in active:
        manifest = load_yaml_file(task_manifest_path(task_id))
        task_title = str(manifest.get("title") or task_id)
        rows.append(f"| [{task_title}](task/{doc_slug(task_id)}.md) | `{task_id}` | {metric_text(manifest)} | {manifest.get('status', 'unknown')} |")
    if not rows:
        rows.append("| None | - | - | - |")
    return f"""{generated_header()}

# {title} Dashboard

AI Lab is a local-first workspace for reusable AI scientist task loops.

<div class="ai-lab-kpi">
  <div><strong>{len(active)}</strong>active task{'s' if len(active) != 1 else ''}</div>
  <div><strong>Git</strong>tracks task structure</div>
  <div><strong>local</strong>experiment logs</div>
  <div><strong>sync</strong>generated docs</div>
</div>

## Active Tasks

| Task | ID | Metric | Status |
| --- | --- | --- | --- |
{chr(10).join(rows)}

## Artifact Policy

Repo Git tracks task descriptions, loop specs, scientist instructions, and maintained task infrastructure. Experiment code, results, plots, reports, assets, and run logs stay local under ignored task artifact directories.

## Common Commands

```bash
uv run python bin/ai-lab docs sync
uv run python bin/ai-lab task validate --all
uv run python bin/ai-lab task run btc_benchmark --once --dry-run
uv run python bin/ai-lab docs audit
```
"""


def task_memory_items(task_id: str, filename: str) -> list[dict[str, Any]]:
    data = load_task_memory_file(task_id, filename)
    field = collection_field(filename)
    items = data.get(field, [])
    if not isinstance(items, list):
        return []
    return [item for item in items if isinstance(item, dict)]


def render_memory_table(items: list[dict[str, Any]], columns: list[tuple[str, str]], empty: str) -> str:
    if not items:
        return empty
    header = "| " + " | ".join(label for label, _ in columns) + " |"
    sep = "| " + " | ".join("---" for _ in columns) + " |"
    rows = [header, sep]
    for item in items[:10]:
        values = []
        for _, key in columns:
            value = item.get(key, "")
            if isinstance(value, list):
                value = ", ".join(str(entry) for entry in value)
            values.append(str(value or "-").replace("\n", " "))
        rows.append("| " + " | ".join(values) + " |")
    return "\n".join(rows)


def render_task_memory_doc(task_id: str) -> str:
    insights = task_memory_items(task_id, "insights.yaml")
    negative = task_memory_items(task_id, "negative-results.yaml")
    candidates = task_memory_items(task_id, "candidates.yaml")
    runs = list(reversed(task_memory_items(task_id, "runs.yaml")))
    return f"""## Curated Memory

### Insights

{render_memory_table(insights, [("Status", "status"), ("Claim", "claim"), ("Evidence", "source_run"), ("Next Action", "next_action")], "No promoted insights yet.")}

### Negative Results

{render_memory_table(negative, [("Status", "status"), ("Claim", "claim"), ("Evidence", "source_run"), ("Next Action", "next_action")], "No promoted negative results yet.")}

### Candidates

{render_memory_table(candidates, [("Status", "status"), ("Candidate", "candidate_id"), ("Summary", "summary"), ("Evidence", "source_run")], "No promoted candidates yet.")}

### Recent Curated Runs

{render_memory_table(runs, [("Run", "run_id"), ("Memory", "memory_status"), ("Run Status", "run_status"), ("Summary", "summary"), ("Next Action", "next_action")], "No curated runs yet.")}
"""


def parse_iso_datetime(value: Any) -> dt.datetime | None:
    if not value:
        return None
    try:
        return dt.datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    except ValueError:
        return None


def seconds_between(start: Any, finish: Any) -> float | None:
    start_dt = parse_iso_datetime(start)
    finish_dt = parse_iso_datetime(finish)
    if not start_dt or not finish_dt:
        return None
    return max(0.0, (finish_dt - start_dt).total_seconds())


def short_text(value: Any, limit: int = 220) -> str:
    text = re.sub(r"\s+", " ", str(value or "")).strip()
    if len(text) <= limit:
        return text
    return text[: limit - 1].rstrip() + "..."


def scalar_text(value: Any) -> str:
    if value is None:
        return ""
    return str(value)


def run_anchor(run_id: str) -> str:
    return "run-" + re.sub(r"[^a-zA-Z0-9_-]+", "-", run_id).strip("-")


def candidate_metric_by_run(task_id: str) -> dict[str, dict[str, Any]]:
    metrics: dict[str, dict[str, Any]] = {}
    for candidate in task_memory_items(task_id, "candidates.yaml"):
        run_id = str(candidate.get("promoted_from_run") or candidate.get("source_run") or "")
        if not run_id:
            continue
        evidence = next((value for key, value in candidate.items() if key.endswith("_evidence") and isinstance(value, dict)), {})
        current = metrics.setdefault(run_id, {})
        for key in ("net", "net_funding_aware", "net_next_open", "net_cost5x", "max_drawdown", "random_pctile", "turnover"):
            if key in evidence:
                current[key] = evidence[key]
        current["candidate_id"] = candidate.get("candidate_id", "")
    return metrics


def task_run_summaries(task_id: str) -> list[dict[str, Any]]:
    runs_dir = task_dir(task_id) / "runs"
    curated_items = task_memory_items(task_id, "runs.yaml")
    curated = {str(item.get("run_id")): item for item in curated_items}
    metrics = candidate_metric_by_run(task_id)
    insight_counts: dict[str, int] = {}
    negative_counts: dict[str, int] = {}
    for item in task_memory_items(task_id, "insights.yaml"):
        run_id = str(item.get("source_run") or "")
        insight_counts[run_id] = insight_counts.get(run_id, 0) + 1
    for item in task_memory_items(task_id, "negative-results.yaml"):
        run_id = str(item.get("source_run") or "")
        negative_counts[run_id] = negative_counts.get(run_id, 0) + 1
    summaries: list[dict[str, Any]] = []
    for item in curated_items:
        run_id = str(item.get("run_id") or "")
        if not run_id:
            continue
        duration = item.get("duration_seconds")
        if duration is None:
            duration = seconds_between(item.get("started_at"), item.get("finished_at")) or 0.0
        cycle_durations = item.get("agent_durations_seconds", [])
        if not isinstance(cycle_durations, list):
            cycle_durations = []
        summaries.append(
            {
                "run_id": run_id,
                "anchor": run_anchor(run_id),
                "status": item.get("run_status", "unknown"),
                "started_at": scalar_text(item.get("started_at")),
                "finished_at": scalar_text(item.get("finished_at")),
                "duration_seconds": float(duration or 0.0),
                "wandb_url": item.get("wandb_url"),
                "agent_cycles": int(item.get("agent_cycles") or len(cycle_durations)),
                "last_cycle": int(item.get("last_cycle") or item.get("agent_cycles") or len(cycle_durations)),
                "command_count": int(item.get("command_count") or 0),
                "artifact_count": int(item.get("artifact_count") or 0),
                "observation_count": int(item.get("observation_count") or 0),
                "insight_count": insight_counts.get(run_id, 0),
                "negative_count": negative_counts.get(run_id, 0),
                "memory_status": item.get("memory_status", "-"),
                "summary": item.get("summary", ""),
                "next_action": item.get("next_action", ""),
                "failure": item.get("failure", ""),
                "metrics": metrics.get(run_id, {}),
                "agent_durations": [float(value or 0.0) for value in cycle_durations],
            }
        )
    for run_json in sorted(runs_dir.glob("*/run.json")):
        run_dir = run_json.parent
        metadata = read_json_file(run_json)
        run_id = str(metadata.get("run_id") or run_dir.name)
        if run_id in curated:
            continue
        events = read_jsonl(run_dir / "events.jsonl")
        observations = read_jsonl(run_dir / "observations.jsonl")
        command_finishes = [event for event in events if event.get("event") == "command_finish"]
        agent_finishes = [event for event in command_finishes if event.get("group") == "agent"]
        failed = next((event for event in reversed(events) if event.get("event") == "run_failed"), {})
        cycles = [int(event.get("cycle", 0)) for event in agent_finishes if isinstance(event.get("cycle"), int)]
        all_cycles = [int(event.get("cycle", 0)) for event in events if isinstance(event.get("cycle"), int)]
        duration = seconds_between(metadata.get("started_at"), metadata.get("finished_at"))
        if duration is None:
            duration = sum(float(event.get("duration_seconds") or 0.0) for event in command_finishes)
        primary_observation = observations[-1] if observations else {}
        curated_run = curated.get(run_id, {})
        summaries.append(
            {
                "run_id": run_id,
                "anchor": run_anchor(run_id),
                "status": metadata.get("status") or curated_run.get("run_status") or infer_run_status(run_dir),
                "started_at": metadata.get("started_at"),
                "finished_at": metadata.get("finished_at"),
                "duration_seconds": duration,
                "wandb_url": metadata.get("wandb_url") or curated_run.get("wandb_url"),
                "agent_cycles": len(agent_finishes),
                "last_cycle": max(all_cycles) if all_cycles else 0,
                "command_count": len(command_finishes),
                "artifact_count": len(read_jsonl(run_dir / "artifacts.jsonl")),
                "observation_count": len(observations),
                "insight_count": insight_counts.get(run_id, 0),
                "negative_count": negative_counts.get(run_id, 0),
                "memory_status": curated_run.get("memory_status", "-"),
                "summary": curated_run.get("summary") or primary_observation.get("claim") or failed.get("message", ""),
                "next_action": curated_run.get("next_action") or primary_observation.get("next_action", ""),
                "failure": failed.get("message", ""),
                "metrics": metrics.get(run_id, {}),
                "agent_durations": [float(event.get("duration_seconds") or 0.0) for event in agent_finishes],
            }
        )
    return summaries


def json_for_script(data: dict[str, Any]) -> str:
    return json.dumps(data, sort_keys=True).replace("</", "<\\/")


def vega_container(chart_id: str, spec: dict[str, Any]) -> str:
    escaped_id = html.escape(chart_id)
    return f"""<div class="ai-lab-vega" id="{escaped_id}"></div>
<script type="application/json" class="ai-lab-vega-spec" data-target="{escaped_id}">
{json_for_script(spec)}
</script>"""


def vega_base_spec(title: str, data: list[dict[str, Any]], *, height: int = 220) -> dict[str, Any]:
    return {
        "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
        "title": title,
        "width": "container",
        "height": height,
        "data": {"values": data},
        "params": [{"name": "zoom", "select": {"type": "interval", "encodings": ["x"], "bind": "scales"}}],
        "config": {
            "axis": {"labelFontSize": 12, "titleFontSize": 12},
            "title": {"fontSize": 14, "anchor": "start"},
            "view": {"stroke": "transparent"},
        },
    }


def vega_line_spec(title: str, rows: list[dict[str, Any]], y_field: str, y_title: str) -> dict[str, Any]:
    spec = vega_base_spec(title, rows)
    spec.update(
        {
            "mark": {"type": "line", "point": True, "tooltip": True},
            "encoding": {
                "x": {
                    "field": "run_label",
                    "type": "ordinal",
                    "sort": {"field": "run_order", "order": "ascending"},
                    "title": "Run ID",
                    "axis": {"labelAngle": -35},
                },
                "y": {"field": y_field, "type": "quantitative", "title": y_title},
                "color": {"value": "#14765c"},
                "tooltip": [
                    {"field": "run_id", "type": "nominal", "title": "Run"},
                    {"field": "status", "type": "nominal", "title": "Status"},
                    {"field": y_field, "type": "quantitative", "title": y_title},
                    {"field": "started_at", "type": "nominal", "title": "Started"},
                ],
                "href": {"field": "href", "type": "nominal"},
            },
        }
    )
    return spec


def vega_bar_spec(title: str, rows: list[dict[str, Any]], y_field: str, y_title: str) -> dict[str, Any]:
    spec = vega_base_spec(title, rows, height=190)
    spec.update(
        {
            "mark": {"type": "bar", "tooltip": True},
            "encoding": {
                "x": {"field": "cycle", "type": "ordinal", "title": "Cycle", "axis": {"labelAngle": 0}},
                "y": {"field": y_field, "type": "quantitative", "title": y_title},
                "color": {"value": "#14765c"},
                "tooltip": [
                    {"field": "cycle", "type": "ordinal", "title": "Cycle"},
                    {"field": "duration_minutes", "type": "quantitative", "title": "Minutes", "format": ".1f"},
                ],
            },
        }
    )
    return spec


def render_run_explorer(task_id: str) -> str:
    runs = task_run_summaries(task_id)
    if not runs:
        return "## Run Explorer\n\nNo run artifacts found yet."
    progress_rows = []
    for index, run in enumerate(runs, start=1):
        metrics = run.get("metrics", {}) if isinstance(run.get("metrics"), dict) else {}
        run_id = str(run.get("run_id") or "")
        row = {
            "run_order": index,
            "run_id": run_id,
            "run_label": run_id.replace("btc_benchmark-", ""),
            "href": f"#{run.get('anchor')}",
            "status": run.get("status", ""),
            "started_at": run.get("started_at", ""),
            "agent_cycles": int(run.get("agent_cycles") or 0),
            "memory_entries": int(run.get("insight_count") or 0) + int(run.get("negative_count") or 0),
            "runtime_minutes": round(float(run.get("duration_seconds") or 0.0) / 60.0, 3),
        }
        if "net" in metrics:
            row["candidate_net"] = metrics["net"]
        progress_rows.append(row)
    rows = [
        "| Run | Status | Cycles | Runtime | Memory | Candidate Net | W&B |",
        "| --- | --- | --- | --- | --- | --- | --- |",
    ]
    for run in runs:
        metrics = run.get("metrics", {}) if isinstance(run.get("metrics"), dict) else {}
        runtime = f"{float(run.get('duration_seconds') or 0) / 60:.1f} min"
        memory = f"{run.get('insight_count', 0)} insight / {run.get('negative_count', 0)} negative"
        net = f"{float(metrics['net']):.4f}" if "net" in metrics else "-"
        wandb = f"[trace]({run['wandb_url']})" if run.get("wandb_url") else "-"
        rows.append(f"| [{run['run_id']}](#{run['anchor']}) | {run['status']} | {run['agent_cycles']} | {runtime} | {memory} | {net} | {wandb} |")

    detail_blocks = []
    for run in runs:
        metrics = run.get("metrics", {}) if isinstance(run.get("metrics"), dict) else {}
        metric_items = []
        for key, label in (
            ("net", "Net"),
            ("net_funding_aware", "Funding-aware"),
            ("net_next_open", "Next-open"),
            ("net_cost5x", "Cost5x"),
            ("max_drawdown", "Max drawdown"),
            ("random_pctile", "Random pctile"),
            ("turnover", "Turnover"),
        ):
            if key in metrics:
                value = metrics[key]
                metric_items.append(f"<div><strong>{html.escape(str(value))}</strong>{html.escape(label)}</div>")
        if not metric_items:
            metric_items.append("<div><strong>-</strong>No promoted candidate metric</div>")
        cycle_rows = [
            {"cycle": index, "duration_seconds": value, "duration_minutes": value / 60.0}
            for index, value in enumerate(run.get("agent_durations", []), start=1)
        ]
        cycle_chart = vega_container(
            f"{run['anchor']}-cycle-duration",
            vega_bar_spec("Agent cycle duration", cycle_rows, "duration_minutes", "Minutes"),
        )
        details = f"""<details class="ai-lab-run-detail" id="{html.escape(str(run['anchor']))}">
<summary><span>{html.escape(str(run['run_id']))}</span><small>{html.escape(str(run['status']))} · {int(run.get('agent_cycles') or 0)} cycles · {float(run.get('duration_seconds') or 0) / 60:.1f} min</small></summary>

<div class="ai-lab-kpi ai-lab-run-kpi">
{''.join(metric_items)}
<div><strong>{int(run.get('insight_count') or 0)}</strong>insights</div>
<div><strong>{int(run.get('negative_count') or 0)}</strong>negative results</div>
</div>

{cycle_chart}

| Field | Value |
| --- | --- |
| Started | {run.get('started_at') or '-'} |
| Finished | {run.get('finished_at') or '-'} |
| Commands | {run.get('command_count', 0)} |
| Artifacts | {run.get('artifact_count', 0)} |
| Observations | {run.get('observation_count', 0)} |
| Failure | {short_text(run.get('failure') or '-', 160)} |

**Summary:** {html.escape(short_text(run.get('summary'), 500))}

**Next Action:** {html.escape(short_text(run.get('next_action'), 500))}

</details>"""
        detail_blocks.append(details)

    return f"""## Run Explorer

### Progress

{vega_container(f"{task_id}-candidate-net", vega_line_spec("Promoted candidate net by run", [row for row in progress_rows if "candidate_net" in row], "candidate_net", "Net"))}

{vega_container(f"{task_id}-agent-cycles", vega_line_spec("Completed agent cycles by run", progress_rows, "agent_cycles", "Cycles"))}

{vega_container(f"{task_id}-memory-entries", vega_line_spec("Curated memory entries by run", progress_rows, "memory_entries", "Entries"))}

### Run Index

{chr(10).join(rows)}

### Run Detail

{chr(10).join(detail_blocks)}
"""


def render_task_doc(task_id: str) -> str:
    manifest = load_yaml_file(task_manifest_path(task_id))
    loop = load_yaml_file(task_loop_path(task_id))
    title = str(manifest.get("title") or task_id)
    loop_cfg = loop.get("loop", {}) if isinstance(loop.get("loop"), dict) else {}
    constraints = manifest.get("constraints", [])
    if isinstance(constraints, list) and constraints:
        constraints_text = "\n".join(f"- {item}" for item in constraints)
    else:
        constraints_text = "- None declared."
    return f"""{generated_header()}

# {title}

## Goal

{manifest.get("goal", "")}

## Contract

| Field | State |
| --- | --- |
| Task ID | `{task_id}` |
| Status | `{manifest.get("status", "unknown")}` |
| Metric | {metric_text(manifest)} |
| Sources | {task_sources_text(manifest)} |
| Observability | {observability_text(load_lab_config())} |

## Loop

| Field | State |
| --- | --- |
| Mode | `{loop_cfg.get("mode", "unknown")}` |
| Max cycles | `{loop_cfg.get("max_cycles", "not set")}` |
| Max wall minutes | `{loop_cfg.get("max_wall_minutes", "not set")}` |
| Stop file | `{loop_cfg.get("stop_file", "STOP")}` |

## Clean Start

No experiment code, assets, reports, plots, results, or run logs are tracked as canonical repo state. Those files are local experiment logs and are ignored by Git.

## Constraints

{constraints_text}

## Workspace

""" + "\n".join(f"- `{item}`" for item in task_dirs(task_id)) + f"""

{render_task_memory_doc(task_id)}

{render_run_explorer(task_id)}

## Run

```bash
uv run python bin/ai-lab task validate {task_id}
uv run python bin/ai-lab task run {task_id} --once --dry-run
uv run python bin/ai-lab task run {task_id} --continuous
```
"""


def render_task_readme(task_id: str) -> str:
    manifest = load_yaml_file(task_manifest_path(task_id))
    title = str(manifest.get("title") or task_id)
    return f"""{generated_header()}

# {title}

This task workspace tracks the task contract and the AI scientist operating structure. Experiment products are local logs and are ignored by repo Git.

- `task.yaml`: task contract, metric, constraints, source refs, and curated asset declarations.
- `loop.yaml`: runnable AI scientist loop.
- `scientist.md`: agent-facing instructions.
- `memory/`: tracked curated run memory for future runs and generated docs.
- `bin/`: maintained task-specific helper scripts.
- `code/`: ignored local experiment code.
- `results/`: ignored local experiment results.
- `plots/`: ignored local experiment plots.
- `reports/`: ignored local experiment reports.
- `runs/`: ignored raw run output.
- `assets/`: ignored local task assets.
"""


def generated_docs() -> dict[Path, str]:
    outputs: dict[Path, str] = {DOCS / "index.md": render_docs_index()}
    for task_id in active_task_ids():
        outputs[DOCS / "task" / f"{doc_slug(task_id)}.md"] = render_task_doc(task_id)
        outputs[task_dir(task_id) / "README.md"] = render_task_readme(task_id)
    return outputs


def cmd_docs_sync(args: argparse.Namespace) -> None:
    outputs = generated_docs()
    stale: list[str] = []
    for path, expected in outputs.items():
        if args.check:
            if not path.exists() or path.read_text(encoding="utf-8") != expected:
                stale.append(rel_display(path))
            continue
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(expected, encoding="utf-8")
        print(f"synced: {rel_display(path)}")
    if args.check:
        if stale:
            print("Docs sync check failed:")
            for path in stale:
                print(f"- stale: {path}")
            raise SystemExit(1)
        print("Docs sync check passed.")


def check_docs_synced(issues: list[str]) -> None:
    for path, expected in generated_docs().items():
        if not path.exists():
            issues.append(f"generated docs missing: {rel_display(path)}")
        elif path.read_text(encoding="utf-8") != expected:
            issues.append(f"generated docs stale: {rel_display(path)}")


def check_docs_links(issues: list[str]) -> None:
    for path in sorted(DOCS.rglob("*.md")):
        text = path.read_text(encoding="utf-8")
        for match in re.finditer(r"\[[^\]]*\]\(([^)]+)\)", text):
            target = match.group(1).strip()
            if target.startswith(("http://", "https://", "mailto:", "#")):
                continue
            target_path = urllib.parse.unquote(target.split("#", 1)[0])
            if not target_path:
                continue
            resolved = (path.parent / target_path).resolve()
            if not (resolved.exists() or resolved.with_suffix(".md").exists() or (resolved / "index.md").exists()):
                issues.append(f"broken docs link: {path.relative_to(ROOT)} -> {target}")


def check_static_assets(issues: list[str]) -> None:
    assets = DOCS / "assets"
    if not assets.exists():
        return
    for path in sorted(assets.glob("*.json")):
        try:
            json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError as exc:
            issues.append(f"invalid JSON: {path.relative_to(ROOT)}: {exc}")


def check_task_docs(issues: list[str]) -> None:
    if not CONFIG.exists():
        issues.append("missing lab.yaml")
    for task_id in active_task_ids():
        task = task_dir(task_id)
        for required in [task / "README.md", task / "task.yaml", task / "loop.yaml", task / "scientist.md"]:
            if not required.exists():
                issues.append(f"missing task file: {rel_display(required)}")
        public_task = DOCS / "task" / f"{doc_slug(task_id)}.md"
        if not public_task.exists():
            issues.append(f"missing public task page: {public_task.relative_to(ROOT)}")


def check_public_docs(issues: list[str]) -> None:
    for path in sorted(DOCS.rglob("*.md")):
        text = path.read_text(encoding="utf-8")
        if re.search(r"^audience:\s*agent\s*$", text, re.MULTILINE):
            issues.append(f"agent-only page must not be under public docs: {path.relative_to(ROOT)}")


def cmd_docs_audit(args: argparse.Namespace) -> None:
    issues: list[str] = []
    check_docs_synced(issues)
    check_static_assets(issues)
    check_docs_links(issues)
    check_task_docs(issues)
    check_public_docs(issues)
    if issues:
        print("Docs audit failed:")
        for issue in issues:
            print(f"- {issue}")
        raise SystemExit(1)
    print("Docs audit passed.")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage the AI Lab workspace.")
    sub = parser.add_subparsers(dest="area", required=True)

    task = sub.add_parser("task", help="manage task workspaces")
    task_sub = task.add_subparsers(dest="cmd", required=True)
    p = task_sub.add_parser("status")
    p.add_argument("task_id")
    p.set_defaults(func=cmd_task_status)
    p = task_sub.add_parser("validate")
    p.add_argument("task_id", nargs="?")
    p.add_argument("--all", action="store_true")
    p.set_defaults(func=cmd_task_validate)
    p = task_sub.add_parser("run", help="execute a task-local AI scientist loop")
    p.add_argument("task_id")
    mode = p.add_mutually_exclusive_group(required=True)
    mode.add_argument("--once", action="store_true")
    mode.add_argument("--continuous", action="store_true")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--run-id")
    p.add_argument("--max-cycles", type=int)
    p.add_argument("--no-wandb", action="store_true", help="test-only opt-out for W&B observability")
    p.set_defaults(func=cmd_task_run)
    p = task_sub.add_parser("summarize", help="regenerate structured files and summary for a run")
    p.add_argument("task_id")
    p.add_argument("--run-id", required=True)
    p.set_defaults(func=cmd_task_summarize)

    agent = sub.add_parser("agent", help="inspect agent prompts")
    agent_sub = agent.add_subparsers(dest="cmd", required=True)
    p = agent_sub.add_parser("prompt")
    p.add_argument("task_id")
    p.add_argument("--run-id", required=True)
    p.add_argument("--cycle", type=int, required=True)
    p.set_defaults(func=cmd_agent_prompt)

    source = sub.add_parser("source", help="manage source code references")
    source_sub = source.add_subparsers(dest="cmd", required=True)
    p = source_sub.add_parser("status")
    p.add_argument("source_id")
    p.set_defaults(func=cmd_source_status)
    p = source_sub.add_parser("materialize")
    p.add_argument("source_id")
    p.add_argument("--ref")
    p.add_argument("--force", action="store_true")
    p.set_defaults(func=cmd_source_materialize)

    runtime = sub.add_parser("runtime", help="check or ensure allowlisted runtime profiles")
    runtime_sub = runtime.add_subparsers(dest="cmd", required=True)
    p = runtime_sub.add_parser("check")
    p.add_argument("profile", choices=sorted(RUNTIME_PROFILES))
    p.add_argument("--repo")
    p.set_defaults(func=cmd_runtime_check)
    p = runtime_sub.add_parser("ensure")
    p.add_argument("profile", choices=sorted(RUNTIME_PROFILES))
    p.add_argument("--repo")
    p.set_defaults(func=cmd_runtime_ensure)

    docs = sub.add_parser("docs", help="audit public documentation")
    docs_sub = docs.add_subparsers(dest="cmd", required=True)
    p = docs_sub.add_parser("sync")
    p.add_argument("--check", action="store_true", help="fail if generated docs are stale")
    p.set_defaults(func=cmd_docs_sync)
    p = docs_sub.add_parser("audit")
    p.set_defaults(func=cmd_docs_audit)

    p = sub.add_parser("memory", help="search and maintain AI Lab memory")
    p.add_argument("memory_args", nargs=argparse.REMAINDER)
    p.set_defaults(func=cmd_memory)
    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    if getattr(args, "cmd", None) == "validate" and not args.all and not args.task_id:
        raise SystemExit("Specify task_id, or use --all.")
    args.func(args)


if __name__ == "__main__":
    main()
