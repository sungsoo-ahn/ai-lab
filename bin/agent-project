#!/bin/sh
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

usage() {
  echo "Deprecated: use ai-lab task/scientist instead." >&2
  echo "Usage: agent-project <init|status|restart|archive> <project_id>" >&2
}

[ "$#" -ge 2 ] || { usage; exit 2; }
cmd="$1"
project_id="$2"

case "$cmd" in
  init)
    exec "$root/bin/ai-lab" task init "$project_id"
    ;;
  status)
    scientists_dir="$root/tasks/active/$project_id/scientists"
    if [ -d "$scientists_dir" ]; then
      count="$(find "$scientists_dir" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
      if [ "$count" = "1" ]; then
        scientist_id="$(basename "$(find "$scientists_dir" -mindepth 1 -maxdepth 1 -type d | sed -n '1p')")"
        exec "$root/bin/ai-lab" scientist status "$project_id" "$scientist_id"
      fi
    fi
    exec "$root/bin/ai-lab" task status "$project_id"
    ;;
  restart)
    exec "$root/bin/ai-lab" task restart "$project_id"
    ;;
  archive)
    exec "$root/bin/ai-lab" task archive "$project_id"
    ;;
  *)
    usage
    exit 2
    ;;
esac
