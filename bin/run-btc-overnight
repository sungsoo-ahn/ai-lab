#!/usr/bin/env bash
set -u

cd "$(dirname "$0")/.."

run_prefix="${1:-btc-overnight-$(date -u +%Y%m%dT%H%M%SZ)}"
log_dir="logs/overnight"
mkdir -p "$log_dir"

autoresearch_run="${run_prefix}-autoresearch"
autoresearch_cell="btc_benchmark__autoresearch__overnight_v1"
autoresearch_run_dir="evaluations/active/${autoresearch_cell}/runs/${autoresearch_run}"
autoresearch_log="${log_dir}/${autoresearch_run}.log"

echo "Launching BTC AutoResearch overnight run."
echo "AutoResearch run: ${autoresearch_run}"
echo "Logs: ${log_dir}/"
echo "AutoResearch launcher log: ${autoresearch_log}"
echo "AutoResearch run dir: ${autoresearch_run_dir}"

uv run python bin/ai-lab cell run "$autoresearch_cell" \
  --continuous \
  --run-id "$autoresearch_run" \
  > "$autoresearch_log" 2>&1 &
autoresearch_pid=$!

autoresearch_status=0

wait "$autoresearch_pid" || autoresearch_status=$?

echo "AutoResearch status: ${autoresearch_status}"

if [ "$autoresearch_status" -ne 0 ]; then
  echo "BTC AutoResearch overnight run failed."
  echo "AutoResearch:"
  echo "  launcher: ${autoresearch_log}"
  echo "  events: ${autoresearch_run_dir}/events.jsonl"
  echo "  commands: ${autoresearch_run_dir}/commands/"
  echo "  summary: ${autoresearch_run_dir}/run-summary.md"
  exit 1
fi

echo "BTC AutoResearch overnight run completed."
