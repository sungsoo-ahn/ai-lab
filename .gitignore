# Local/transient agent artifacts
.DS_Store
*.tmp
*.log
.env
*.env

# Python and tool caches
.venv/
.ruff_cache/
.pytest_cache/
__pycache__/

# Generated memory/search indexes
memory/*.sqlite
site/

# Keep raw private exports and bulky generated artifacts out of the audit repo.
inbox/raw/**
!inbox/raw/
!inbox/raw/.gitkeep
inbox/repos/**
!inbox/repos/
!inbox/repos/.gitkeep
sources/checkouts/**
!sources/checkouts/
!sources/checkouts/.gitkeep

# Task definitions and scaffold are tracked; experiment products are local logs.
tasks/*/assets/**
!tasks/*/assets/
!tasks/*/assets/.gitkeep
tasks/*/code/**
!tasks/*/code/
!tasks/*/code/.gitkeep
tasks/*/plots/**
!tasks/*/plots/
!tasks/*/plots/.gitkeep
tasks/*/reports/**
!tasks/*/reports/
!tasks/*/reports/.gitkeep
tasks/*/results/**
!tasks/*/results/
!tasks/*/results/.gitkeep
!tasks/*/results/curated/
!tasks/*/results/curated/.gitkeep
tasks/*/runs/**
!tasks/*/runs/
!tasks/*/runs/.gitkeep
tasks/*/tmp/
tasks/*/*-raw/
